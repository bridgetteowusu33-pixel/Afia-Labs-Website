---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookPreview from '../components/BookPreview.astro';

// REPLACE THESE with the real Amazon listing URLs once you have them.
// Tip: when you sign up for Amazon Associates, use your affiliate link
// here so you earn a referral commission on top of the royalty.
const AMAZON_BOOK_PAPERBACK = 'https://www.amazon.com/dp/REPLACE_WITH_BOOK_ASIN';
const AMAZON_BOOK_KINDLE = 'https://www.amazon.com/dp/REPLACE_WITH_KINDLE_ASIN';
const AMAZON_WORKBOOK = 'https://www.amazon.com/dp/REPLACE_WITH_WORKBOOK_ASIN';

// Newsletter signup is repurposed as the Field Guide № 2 announce list.
const waitlistUrl = 'https://form.jotform.com/261045381980054';

const title = 'From Idea to Income with AI Apps — Field Guide № 1 | Afia Labs';
const description =
  'The honest field guide to shipping a real consumer app with AI, from a solo builder who actually did it. Now on Amazon as paperback, Kindle, and a companion workbook. Afia Labs Field Guide № 1.';
---

<BaseLayout title={title} description={description}>
  <main>
    <!-- ========== HERO ========== -->
    <section class="book-hero" aria-label="Book introduction">
      <div class="container">
        <div class="book-hero-grid">
          <div class="book-hero-text">
            <div class="hero-badge">
              <span></span>
              Afia Labs · Field Guide № 1 · Now on Amazon
            </div>
            <h1>
              From idea to income with <span class="accent">AI apps</span>.
            </h1>
            <p class="book-hero-tagline">
              The honest field guide to shipping a real consumer app with AI, from a solo builder who actually did it.
            </p>
            <p class="book-hero-meta">
              By Bridgette Owusu, founder of Afia Labs and builder of MemeScanr. Available now as paperback, Kindle ebook, and a companion workbook.
            </p>
            <div class="book-hero-buttons">
              <a
                href={AMAZON_BOOK_PAPERBACK}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                Buy the Paperback
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a
                href={AMAZON_BOOK_KINDLE}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary"
              >
                Get the Kindle
              </a>
              <a
                href={AMAZON_WORKBOOK}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary"
              >
                Add the Workbook
              </a>
            </div>
            <p class="book-hero-note">
              All three on Amazon. Royalties go straight to one solo builder, not a publisher.
            </p>
          </div>
          <div class="book-hero-cover">
            <BookPreview width="320px" />
          </div>
        </div>
      </div>
    </section>

    <!-- ========== THREE-PART SYSTEM ========== -->
    <section class="book-system" aria-label="The three-part system">
      <div class="container">
        <div class="section-header">
          <div class="section-label">The System</div>
          <h2 class="section-title">Belief. Clarity. Execution.</h2>
          <p class="section-subtitle">
            Three products. One ownership-first system for builders who want to use AI without becoming a passenger to it.
          </p>
        </div>

        <div class="system-grid">
          <div class="system-card fade-in">
            <div class="system-icon">📖</div>
            <div class="system-step">Step 1</div>
            <h3>The Book</h3>
            <p>
              The belief-builder. 19 chapters. Real stories from launching MemeScanr — Apple rejections, trust bugs, pricing experiments, the post-launch emotional arc nobody warns you about.
            </p>
            <div class="system-meta">~41,000 words · ebook + print</div>
          </div>

          <div class="system-card fade-in">
            <div class="system-icon">📓</div>
            <div class="system-step">Step 2</div>
            <h3>The Workbook</h3>
            <p>
              The clarity-builder. 88 pages of prompts, worksheets, and decision tools that walk you from "I have an itch" to "I shipped a thing." Companion to the book.
            </p>
            <div class="system-meta">88 pages · printable + digital</div>
          </div>

          <div class="system-card fade-in">
            <div class="system-icon">🎥</div>
            <div class="system-step">Step 3</div>
            <h3>The Course</h3>
            <p>
              The execution layer. Pre-recorded video lessons that walk you through the whole process with my voice. Templates, prompt pack, and the launch audit prompt included.
            </p>
            <div class="system-meta">11 modules · launching after the book</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WHO IT'S FOR ========== -->
    <section class="book-audience" aria-label="Who this is for">
      <div class="container">
        <div class="audience-grid">
          <div class="audience-text">
            <div class="section-label">Who It's For</div>
            <h2 class="section-title">For the builder who keeps almost starting.</h2>
            <p>
              Most books about building with AI are written by people who have read a lot of tweets and shipped nothing. This is not that book. I wrote it on the other side of four months of real shipping — twenty-seven builds, one Apple rejection, and one launch day that felt nothing like anyone had told me.
            </p>
          </div>
          <ul class="audience-list">
            <li>
              <span class="audience-check">✓</span>
              <div>
                <strong>The builder who keeps almost starting.</strong>
                The one with a notes app full of ideas and zero shipped products.
              </div>
            </li>
            <li>
              <span class="audience-check">✓</span>
              <div>
                <strong>The first-time solo founder.</strong>
                Building under her own name, no cofounder, no VC, no permission.
              </div>
            </li>
            <li>
              <span class="audience-check">✓</span>
              <div>
                <strong>The master driver in training.</strong>
                Who wants to use AI without becoming a passenger to it.
              </div>
            </li>
            <li>
              <span class="audience-check">✓</span>
              <div>
                <strong>The honest builder.</strong>
                Who wants the real story, the scars, and the receipts — not the highlight reel.
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ========== WHAT'S INSIDE ========== -->
    <section id="whats-inside" class="book-inside" aria-label="What's inside">
      <div class="container">
        <div class="section-header">
          <div class="section-label">What's Inside</div>
          <h2 class="section-title">Real stories. Real frameworks. Real receipts.</h2>
          <p class="section-subtitle">
            Every chapter is anchored in a moment from building MemeScanr. No theory. No success porn. Just the work.
          </p>
        </div>

        <div class="inside-grid">
          <div class="inside-card fade-in">
            <div class="inside-number">01</div>
            <h3>The Master Driver Framework</h3>
            <p>Why the relationship you have with AI matters more than the tool you pick. The passenger, the fighter, and the master driver — choose carefully.</p>
          </div>

          <div class="inside-card fade-in">
            <div class="inside-number">02</div>
            <h3>The Real AI Workflow</h3>
            <p>The prompt template, question stack, AI session log, and rules of engagement I use every single day. Built for solo builders, not enterprise teams.</p>
          </div>

          <div class="inside-card fade-in">
            <div class="inside-number">03</div>
            <h3>The Smallest Useful Version</h3>
            <p>Why MemeScanr v1.0 shipped with one feature. Why cutting features turned into launches I earned. The Feature Temptation Log you can steal today.</p>
          </div>

          <div class="inside-card fade-in">
            <div class="inside-number">04</div>
            <h3>The Pre-Submission Audit</h3>
            <p>The 25-item checklist that has saved me from multiple Apple rejections. Plus the real one I got — guideline 5.1.1(iv) — and exactly how I fixed it in three days.</p>
          </div>

          <div class="inside-card fade-in">
            <div class="inside-number">05</div>
            <h3>Pricing Like You Mean It</h3>
            <p>The anchoring staircase ($6.99 / $24.99 / $59.99). The two-trial strategy. The free-tier-that-wasn't-gated story that tripled conversion.</p>
          </div>

          <div class="inside-card fade-in">
            <div class="inside-number">06</div>
            <h3>The Post-Launch Emotional Map</h3>
            <p>Week 1 elation. Week 3 doubt. Week 8 you forget you doubted. The letter to the builder you're becoming. The map nobody warns you about.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FOUNDER STORY ========== -->
    <section class="book-story" aria-label="Founder story">
      <div class="container">
        <div class="story-card">
          <div class="section-label" style="color: #fb923c;">The Origin</div>
          <h2 class="story-title">The Tuesday my camera roll broke me.</h2>
          <div class="story-body">
            <p>
              It was a Tuesday. I was trying to send a screenshot to a friend, just a dumb meme I had saved three months earlier, and I could not find it. I scrolled past forty-seven variations of the same selfie. I scrolled past a screenshot of a parking meter I did not remember paying. I scrolled past a video of a sunset that was probably beautiful but now just felt like a stranger. I kept scrolling. My thumb started to ache. My phone said 14,823 photos.
            </p>
            <p>
              I closed the Photos app and opened Instagram instead.
            </p>
            <p>
              That was the moment I had the idea for MemeScanr. Not the pitch. Not the plan. Just the feeling: <em>my phone is full of things I do not remember saving and will never look at again, and it is making me feel like a bad tenant in my own life.</em>
            </p>
            <p>
              Four months later, MemeScanr is in the App Store. I built it as a solo builder, with AI tools, while staying in the driver's seat the entire time. This book is everything I wish someone had handed me on the Tuesday it all started.
            </p>
          </div>
          <div class="story-byline">— Bridgette Owusu, Afia Labs</div>
        </div>
      </div>
    </section>

    <!-- ========== BUY CTA ========== -->
    <section class="book-cta" aria-label="Buy on Amazon">
      <div class="container">
        <div class="cta-card">
          <h2>Get Field Guide № 1 on Amazon.</h2>
          <p>
            Paperback, Kindle, and the companion workbook. All available now. Royalties go straight to one solo builder, not a publisher.
          </p>
          <div class="cta-buttons">
            <a
              href={AMAZON_BOOK_PAPERBACK}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary cta-button"
            >
              Buy the Paperback
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href={AMAZON_BOOK_KINDLE}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary cta-button"
            >
              Get the Kindle
            </a>
            <a
              href={AMAZON_WORKBOOK}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary cta-button"
            >
              Add the Workbook
            </a>
          </div>
          <p class="cta-meta">
            Built with AI. Stayed in control. Owned the outcome.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== FIELD GUIDE № 2 NEWSLETTER ========== -->
    <section class="book-newsletter" aria-label="Field Guide № 2 announce list">
      <div class="container">
        <div class="newsletter-card">
          <div class="newsletter-eyebrow">Afia Labs Field Guide Series</div>
          <h2>Field Guide № 2 is in the works.</h2>
          <p>
            One email when the next volume is ready. No spam. No pre-launch noise. Just the announcement, the first sample, and the launch-week price.
          </p>
          <a
            href={waitlistUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            Get Notified About № 2
          </a>
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section class="book-faq" aria-label="Frequently asked questions">
      <div class="container">
        <div class="section-header">
          <div class="section-label">Questions</div>
          <h2 class="section-title">Everything you might be wondering.</h2>
        </div>

        <div class="faq-list">
          <details class="faq-item">
            <summary>Where can I buy it?</summary>
            <p>Amazon — paperback, Kindle ebook, and the companion workbook (paperback). Use the buttons above. The course is in production and will be announced separately.</p>
          </details>

          <details class="faq-item">
            <summary>What does it cost?</summary>
            <p>Set on the Amazon listings. Each format is priced independently — buy the one that fits. Workbook readers tend to also buy the book; book readers don't always need the workbook.</p>
          </details>

          <details class="faq-item">
            <summary>What format is the book?</summary>
            <p>6 × 9 in trade paperback (Amazon print on demand) and Kindle ebook. The workbook is also a 6 × 9 paperback designed to be filled in. The course will be pre-recorded video lessons when it launches.</p>
          </details>

          <details class="faq-item">
            <summary>Why three products instead of one?</summary>
            <p>The book builds belief. The workbook builds clarity. The course builds execution. Each format does a different job, and together they take you from "I have an idea" to "I shipped a thing." You don't have to buy all three — start with what you need.</p>
          </details>

          <details class="faq-item">
            <summary>Is this for me if I'm not technical?</summary>
            <p>Yes. The book is stack-agnostic. It teaches the relationship between you and AI, not the syntax of any specific framework. If you have an itch you can't stop noticing and a willingness to learn as you build, it's for you.</p>
          </details>

          <details class="faq-item">
            <summary>Can I get just the book without the bundle?</summary>
            <p>Yes. The book stands alone. The bundle is for people who want the full system — book + workbook + course. You can also start with the book and upgrade later.</p>
          </details>

          <details class="faq-item">
            <summary>Who is Afia Labs?</summary>
            <p>Afia Labs is a small software studio founded by Bridgette Owusu. We build consumer tools (like MemeScanr) and now learning resources for solo builders. Our principles: on-device by default, voice as design, ownership-first.</p>
          </details>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ========== HERO ========== */
  .book-hero {
    padding: 120px 0 80px;
    background: linear-gradient(180deg, var(--bg-light) 0%, var(--bg-white) 100%);
  }

  .book-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .book-hero h1 {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 24px 0 24px;
  }

  .book-hero h1 .accent {
    color: #fb923c;
  }

  .book-hero-tagline {
    font-size: 20px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin-bottom: 16px;
    max-width: 580px;
  }

  .book-hero-meta {
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 32px;
    max-width: 560px;
  }

  .book-hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .book-hero-note {
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
  }

  .book-hero-cover {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ========== THREE-PART SYSTEM ========== */
  .book-system {
    padding: 80px 0;
    background: var(--bg-white);
  }

  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .system-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: var(--shadow-sm);
  }

  .system-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .system-icon {
    font-size: 40px;
    margin-bottom: 16px;
  }

  .system-step {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: #fb923c;
    margin-bottom: 8px;
  }

  .system-card h3 {
    font-size: 24px;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 14px;
    letter-spacing: -0.01em;
  }

  .system-card p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 20px;
  }

  .system-meta {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding-top: 16px;
    border-top: 1px solid var(--border-light);
  }

  /* ========== AUDIENCE ========== */
  .book-audience {
    padding: 80px 0;
    background: var(--bg-light);
  }

  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .audience-text h2 {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text-primary);
    margin: 16px 0 24px;
    letter-spacing: -0.02em;
  }

  .audience-text p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .audience-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .audience-list li {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 18px 22px;
    background: var(--bg-white);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
  }

  .audience-check {
    flex: 0 0 auto;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #fb923c;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 800;
    margin-top: 2px;
  }

  .audience-list li strong {
    color: var(--text-primary);
    display: block;
    margin-bottom: 4px;
  }

  .audience-list li div {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  /* ========== WHAT'S INSIDE ========== */
  .book-inside {
    padding: 80px 0;
    background: var(--bg-white);
  }

  .inside-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .inside-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    transition: transform 0.3s ease;
  }

  .inside-card:hover {
    transform: translateY(-2px);
  }

  .inside-number {
    font-size: 32px;
    font-weight: 800;
    color: rgba(251, 146, 60, 0.32);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .inside-card h3 {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .inside-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ========== STORY ========== */
  .book-story {
    padding: 80px 0;
    background: var(--bg-light);
  }

  .story-card {
    max-width: 760px;
    margin: 0 auto;
    background: linear-gradient(135deg, #1a0a2e 0%, #2d1b69 100%);
    border-radius: var(--radius-xl);
    padding: 64px 56px;
    color: #fffbf7;
    box-shadow: var(--shadow-xl);
    position: relative;
    overflow: hidden;
  }

  .story-card::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(251, 146, 60, 0.16) 0%, transparent 70%);
  }

  .story-title {
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 800;
    line-height: 1.15;
    margin: 14px 0 28px;
    color: #fffbf7;
    letter-spacing: -0.02em;
    position: relative;
  }

  .story-body p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 251, 247, 0.85);
    margin: 0 0 18px;
    position: relative;
  }

  .story-body em {
    color: #fdba74;
    font-style: italic;
  }

  .story-byline {
    margin-top: 24px;
    font-size: 14px;
    font-weight: 700;
    color: rgba(255, 251, 247, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    position: relative;
  }

  /* ========== CTA ========== */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .book-newsletter {
    padding: 5rem 0 6rem;
  }

  .newsletter-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 2.4rem 2rem;
    border: 1px solid rgba(26, 15, 31, 0.1);
    border-radius: 18px;
    background: #fff;
  }

  .newsletter-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C66A2D;
    margin-bottom: 0.8rem;
  }

  .newsletter-card h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 700;
    font-size: 1.8rem;
    line-height: 1.15;
    margin: 0 0 0.7rem 0;
    color: #1a0f1f;
  }

  .newsletter-card p {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #2d2438;
    margin: 0 0 1.4rem 0;
  }

  .book-cta {
    padding: 80px 0;
    background: var(--bg-white);
  }

  .cta-card {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 64px 48px;
    box-shadow: var(--shadow-md);
  }

  .cta-card h2 {
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .cta-card p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 32px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button {
    font-size: 17px !important;
    padding: 18px 36px !important;
