---
import BaseLayout from '../layouts/BaseLayout.astro';

const url = Astro.url;
const from = url.searchParams.get('from') || '/read-room-r7k92x';
const error = url.searchParams.get('error') === '1';
---

<BaseLayout
  title="Reading Room — Afia Labs"
  description="Private reading room for trusted readers."
  noindex={true}
>
  <main class="access-main">
    <div class="access-card">
      <div class="access-eyebrow">Afia Labs · Field Guide № 1</div>
      <h1 class="access-title">Reading Room</h1>
      <p class="access-lead">
        This is a private preview of the book and workbook for trusted readers.
        If Bridgette gave you a password, enter it below.
      </p>

      <form method="POST" action="/api/reading-access" class="access-form">
        <input type="hidden" name="from" value={from} />
        <label class="access-label" for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          autofocus
          autocomplete="off"
          class="access-input"
        />
        {error && (
          <div class="access-error">That password is not right. Try again, or email Bridgette at support@afialabs.net.</div>
        )}
        <button type="submit" class="access-submit">Open the Reading Room</button>
      </form>

      <p class="access-foot">
        Want the published book instead? <a href="/book">See it on Amazon</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .access-main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    background:
      radial-gradient(circle at 20% 10%, rgba(245, 158, 11, 0.08), transparent 40%),
      radial-gradient(circle at 80% 90%, rgba(245, 158, 11, 0.05), transparent 40%),
      #fbf7f0;
    color: #1a0f1f;
  }

  .access-card {
    max-width: 28rem;
    width: 100%;
    background: #fff;
    border: 1px solid rgba(26, 15, 31, 0.08);
    border-radius: 18px;
    padding: 2.5rem 2.25rem;
    box-shadow: 0 18px 40px -16px rgba(26, 15, 31, 0.18);
  }

  .access-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C66A2D;
    margin-bottom: 1.1rem;
  }

  .access-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #1a0f1f;
    margin: 0 0 0.9rem 0;
  }

  .access-lead {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #2d2438;
    margin: 0 0 1.6rem 0;
  }

  .access-form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .access-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1a0f1f;
  }

  .access-input {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid rgba(26, 15, 31, 0.15);
    border-radius: 10px;
    background: #fbf7f0;
    color: #1a0f1f;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .access-input:focus {
    outline: none;
    border-color: #C66A2D;
    box-shadow: 0 0 0 3px rgba(198, 106, 45, 0.15);
  }

  .access-error {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    color: #b22b2b;
    background: #fdecec;
    border-left: 3px solid #b22b2b;
    padding: 0.55rem 0.7rem;
    border-radius: 6px;
  }

  .access-submit {
    margin-top: 0.5rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: #1a0f1f;
    border: none;
    padding: 0.85rem 1.1rem;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }

  .access-submit:hover {
    background: #2c1d36;
  }

  .access-submit:active {
    transform: translateY(1px);
  }

  .access-foot {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    color: #6b5a72;
    text-align: center;
    margin: 1.6rem 0 0 0;
  }

  .access-foot a {
    color: #C66A2D;
    text-decoration: none;
    font-weight: 600;
  }

  .access-foot a:hover {
    text-decoration: underline;
  }
</style>
