---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Pull the 3 most-recent published Studio essays for the homepage strip.
const studioPosts = (
  await getCollection('studio', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const STUDIO_PILLAR_LABELS: Record<string, string> = {
  'building-with-ai': 'Building with AI',
  'indie-economics': 'Indie Economics',
  'studio-philosophy': 'Studio Philosophy',
  'launch-notes': 'Launch Notes',
  'the-craft': 'The Craft',
};

function fmtStudioDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const title = 'Afia Labs — Apps, Websites, and Field Guides from an Independent Product Studio';
const description =
  'Afia Labs is a founder-led product studio. We ship consumer apps (MemeScanr, TripSquad), build websites for small businesses, and publish field guides for AI app builders.';
---

<BaseLayout title={title} description={description}>
    <main>

    <!-- ========== HERO (broad and brand-led) ========== -->
    <section class="hero" aria-label="Introduction">
        <div class="container hero-content">
            <div class="hero-text">
                <div class="hero-badge">
                    <span></span>
                    Independent Product Studio · Founded by Bridgette Owusu
                </div>
                <h1>One studio for <span class="accent">apps, websites, and practical tools</span> built with care.</h1>
                <p>Afia Labs is a founder-led product studio building useful digital products with personality, ownership, and intention. We design client websites, ship our own apps, and create practical guides for builders learning to stay in control while building with AI.</p>
                <div class="hero-buttons">
                    <a href="/services/" class="btn-primary">
                        Work with the studio
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <a href="/studio/" class="btn-secondary">
                        See what we've built
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-illustration">
                    <div class="hero-glow"></div>
                    <div class="orbit-ring orbit-ring-1"></div>
                    <div class="orbit-ring orbit-ring-2"></div>

                    <div class="device-mockup device-phone">
                        <div class="device-phone-inner">
                            <div class="app-icon-large">⚡</div>
                            <div class="app-name">Afia Labs</div>
                            <div class="app-bar"><div class="app-bar-fill"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:40%"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:80%"></div></div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-1">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-purple-soft">📱</div>
                            <div>
                                <div class="mini-label">Apps</div>
                                <div class="mini-value mini-value-compact">MemeScanr · TripSquad</div>
                            </div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-2">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-gold-soft">🛠️</div>
                            <div>
                                <div class="mini-label">Services</div>
                                <div class="mini-value mini-value-compact">Glam by Cella · Live</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== STUDIO AT A GLANCE (proof band) ========== -->
    <section class="studio-glance" aria-label="Studio at a glance">
        <div class="container">
            <ul class="studio-glance-bar fade-in">
                <li>
                    <a href="/studio/" class="glance-chip">
                        <span class="glance-icon" aria-hidden="true">📱</span>
                        <div>
                            <strong>Apps in the studio</strong>
                            <span>MemeScanr · TripSquad · Planet Wonders in development</span>
                        </div>
                    </a>
                </li>
                <li>
                    <a href="/review/" class="glance-chip">
                        <span class="glance-icon" aria-hidden="true">⭐</span>
                        <div>
                            <strong>5-star on Google</strong>
                            <span>Verified client reviews</span>
                        </div>
                    </a>
                </li>
                <li>
                    <a href="/services/#recent-work" class="glance-chip">
                        <span class="glance-icon" aria-hidden="true">🛠️</span>
                        <div>
                            <strong>Recent client work</strong>
                            <span>Glam by Cella, Virginia</span>
                        </div>
                    </a>
                </li>
                <li>
                    <a href="/services/" class="glance-chip">
                        <span class="glance-icon" aria-hidden="true">📍</span>
                        <div>
                            <strong>Based in Virginia</strong>
                            <span>Serving locally and online</span>
                        </div>
                    </a>
                </li>
                <li>
                    <a href="/book/" class="glance-chip">
                        <span class="glance-icon" aria-hidden="true">📖</span>
                        <div>
                            <strong>Field guide on Amazon</strong>
                            <span>From Idea to Income with AI Apps</span>
                        </div>
                    </a>
                </li>
            </ul>
        </div>
    </section>

    <!-- ========== WHAT WE DO (one studio, four lanes — weighted) ========== -->
    <section id="what-we-do" aria-label="What We Do">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">What We Do</div>
                <h2 class="section-title">One studio, four lanes.</h2>
                <p class="section-subtitle">Afia Labs works across four connected lanes: client websites, consumer apps, field guides, and studio notes. Each one is built with the same focus on usefulness, clarity, and care.</p>
            </div>

            <div class="what-do-large-grid">
                <article class="what-do-large fade-in fade-in-delay-1">
                    <div class="what-do-large-eyebrow">For small businesses</div>
                    <h3>Studio Services — websites, landing pages, and digital systems</h3>
                    <p>We build polished websites for small businesses, creators, and founders. Mobile-first design, booking-ready flows, local SEO, and a clean handoff so you can actually run the site after launch.</p>
                    <a href="/services/" class="btn-primary what-do-cta">
                        Work with us
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </article>

                <article class="what-do-large fade-in fade-in-delay-2">
                    <div class="what-do-large-eyebrow">For everyday life</div>
                    <h3>Consumer Apps — shipped in the App Store</h3>
                    <p>Privacy-first, personality-rich consumer apps. MemeScanr cleans up your camera roll. TripSquad gets your group to take the trip. Planet Wonders teaches kids the world.</p>
                    <a href="/studio/" class="btn-primary what-do-cta">
                        Explore the apps
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </article>
            </div>

            <div class="what-do-small-strip">
                <article class="what-do-small fade-in fade-in-delay-2">
                    <div class="what-do-small-icon">📖</div>
                    <div class="what-do-small-body">
                        <h3>Field Guides</h3>
                        <p>Practical books and workbooks for builders learning to ship with AI. <em>From Idea to Income</em> is on Amazon now.</p>
                        <a href="/book/" class="what-do-small-cta">Read the book →</a>
                    </div>
                </article>
                <article class="what-do-small fade-in fade-in-delay-3">
                    <div class="what-do-small-icon">📝</div>
                    <div class="what-do-small-body">
                        <h3>Studio Notes</h3>
                        <p>Founder notes on building with AI, ownership, and shipping consumer products solo.</p>
                        <a href="/blog/" class="what-do-small-cta">Read the latest →</a>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- ========== RECENT CLIENT WORK (Glam by Cella case study) ========== -->
    <section id="recent-client-work" aria-label="Recent client work" class="home-recent-work">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Recent Client Work</div>
                <h2 class="section-title">Built and launched by Afia Labs Studio.</h2>
                <p class="section-subtitle">A look at the real projects shipping from the studio.</p>
            </div>

            <article class="home-case-study fade-in">
                <div class="case-study-visuals">
                    <a href="https://glambycella.com" target="_blank" rel="noopener noreferrer" class="case-study-screenshot" aria-label="View Glam by Cella website on desktop">
                        <div class="case-study-browser-bar">
                            <span class="case-browser-dot case-browser-dot-red" aria-hidden="true"></span>
                            <span class="case-browser-dot case-browser-dot-yellow" aria-hidden="true"></span>
                            <span class="case-browser-dot case-browser-dot-green" aria-hidden="true"></span>
                            <span class="case-browser-url">glambycella.com</span>
                        </div>
                        <img
                            src="/glambycella-screenshot.jpg"
                            alt="Desktop screenshot of the Glam by Cella website built by Afia Labs Studio"
                            loading="lazy"
                            width="1440"
                            height="900"
                        />
                    </a>
                    <a href="https://glambycella.com" target="_blank" rel="noopener noreferrer" class="case-study-phone" aria-label="View Glam by Cella website on mobile">
                        <span class="case-phone-notch" aria-hidden="true"></span>
                        <img
                            src="/glambycella-screenshot-mobile.jpg"
                            alt="Mobile screenshot of the Glam by Cella website built by Afia Labs Studio"
                            loading="lazy"
                            width="390"
                            height="844"
                        />
                    </a>
                </div>
                <div class="case-study-body">
                    <div class="case-study-eyebrow">Live · Virginia</div>
                    <h3>Glam by Cella</h3>
                    <p>Beauty website and booking flow for a Virginia makeup artist. Polished mobile-first design, integrated booking calendar, clear service pricing, and local-SEO setup so search traffic finds the studio.</p>
                    <ul class="case-study-tags">
                        <li>Website design</li>
                        <li>Booking flow</li>
                        <li>Local SEO</li>
                        <li>Mobile-first build</li>
                    </ul>
                    <div class="case-study-actions">
                        <a href="https://glambycella.com" target="_blank" rel="noopener noreferrer" class="case-study-cta">
                            View glambycella.com →
                        </a>
                        <a href="/services/" class="case-study-cta-secondary">See all studio services →</a>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <!-- ========== FEATURED PRODUCTS (apps) ========== -->
    <section id="apps" aria-label="Featured Products">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Featured Products</div>
                <h2 class="section-title">Featured products.</h2>
                <p class="section-subtitle">A look at the apps and tools being built inside Afia Labs.</p>
            </div>

            <div class="apps-grid">
                <div class="app-card memescanr fade-in fade-in-delay-1">
                    <div class="app-icon"><img src="/memescanr_logo.png" alt="MemeScanr logo"></div>
                    <h3>MemeScanr <span class="status-badge status-live">Live</span></h3>
                    <p class="app-desc">A privacy-first iPhone gallery cleaner with personality.</p>
                    <a href="/memescanr/" class="btn-app">
                        Explore MemeScanr
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="app-card tripsquad fade-in fade-in-delay-2">
                    <div class="app-icon"><img src="/tripsquad_logo.png" alt="TripSquad logo"></div>
                    <h3>TripSquad <span class="status-badge status-live">Live</span></h3>
                    <p class="app-desc">The group-trip planner that helps friends agree, vote, and actually take the trip.</p>
                    <a href="/tripsquad/" class="btn-app">
                        Explore TripSquad
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="app-card planetwonders fade-in fade-in-delay-3">
                    <div class="app-icon"><img src="/planet_wonders_launchscreen.png" alt="Planet Wonders logo"></div>
                    <h3>Planet Wonders <span class="status-badge status-dev">In Development</span></h3>
                    <p class="app-desc">A playful world-learning app for kids around creativity and curiosity.</p>
                    <a href="/studio/#planet-wonders" class="btn-app">
                        Explore Planet Wonders
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== TESTIMONIALS ========== -->
    <section class="home-testimonials" aria-label="What clients are saying">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Testimonials</div>
                <h2 class="section-title">What clients are saying.</h2>
                <p class="section-subtitle">Verified Google reviews from small-business owners we have built for.</p>
            </div>

            <div class="home-testimonials-grid fade-in">
                <blockquote class="home-testimonial-card">
                    <p class="home-testimonial-text">
                        "Afia Labs Studio did an amazing job helping bring my website vision for Glam by Cella to life. Bridgette was creative, professional, and really understood the look and feel I wanted for my beauty business. The final website feels polished, elegant, and easy for clients to use. I would definitely recommend Afia Labs Studio to other small business owners."
                    </p>
                    <footer class="home-testimonial-meta">
                        <span class="home-testimonial-stars" aria-label="5 out of 5 stars">★★★★★</span>
                        <div>
                            <span class="home-testimonial-author">Princella K.</span>
                            <span class="home-testimonial-role">Owner, <a href="https://glambycella.com" target="_blank" rel="noopener noreferrer">Glam by Cella</a></span>
                        </div>
                    </footer>
                </blockquote>

                <blockquote class="home-testimonial-card">
                    <p class="home-testimonial-text">
                        "Bridgette at Afia Labs Studio was amazing to work with. She listened to what I wanted for my business and created a website that feels elegant, professional, and easy for my clients to use. I love that she understood the beauty side of my business and made sure the site matched my brand, not just a generic template. I'm so happy with the final result. Thanks Bridgette."
                    </p>
                    <footer class="home-testimonial-meta">
                        <span class="home-testimonial-stars" aria-label="5 out of 5 stars">★★★★★</span>
                        <div>
                            <span class="home-testimonial-author">Josephine B.</span>
                            <span class="home-testimonial-role">Small-business owner</span>
                        </div>
                    </footer>
                </blockquote>

                <blockquote class="home-testimonial-card">
                    <p class="home-testimonial-text">
                        "Afia Labs Studio exceeded my expectations. From communication to delivery, everything was handled professionally. The website design was modern, responsive, and beautifully done. Definitely one of the best web development experiences I've had."
                    </p>
                    <footer class="home-testimonial-meta">
                        <span class="home-testimonial-stars" aria-label="5 out of 5 stars">★★★★★</span>
                        <div>
                            <span class="home-testimonial-author">Rebecca A.</span>
                            <span class="home-testimonial-role">Web development client</span>
                        </div>
                    </footer>
                </blockquote>
            </div>

            <p class="home-testimonials-source fade-in">
                All quotes are verified Google reviews. <a href="https://g.page/r/CRL7lWvgmT0ZEBI/" target="_blank" rel="noopener noreferrer">Read more on Google →</a>
            </p>
        </div>
    </section>

    <!-- ========== FIELD GUIDE (calmer non-banner section) ========== -->
    <section class="home-field-guide" aria-label="Field Guide">
        <div class="container">
            <div class="field-guide-grid fade-in">
                <div class="field-guide-cover">
                    <img src="/book-cover.jpg" alt="From Idea to Income with AI Apps — Afia Labs Field Guide No 1" loading="lazy" />
                </div>
                <div class="field-guide-body">
                    <div class="field-guide-eyebrow">Field Guide № 1 · On Amazon</div>
                    <h2>Build with AI. Stay in control. Own the outcome.</h2>
                    <p>From Idea to Income with AI Apps is the practical field guide to shipping a real consumer app with AI. Paperback, Kindle, and a companion workbook are live on Amazon.</p>
                    <a href="/book/" class="btn-primary">
                        Explore the book
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== FOUNDER NOTE (compact, BEFORE the studio essay strip) ========== -->
    <section id="founder-note" aria-label="Founder Note">
        <div class="container">
            <div class="founder-note-grid">
                <div class="founder-note-visual fade-in">
                    <img src="/founder.jpg" alt="Bridgette Owusu, founder of Afia Labs" class="founder-note-photo" loading="lazy">
                </div>
                <div class="founder-note-body fade-in fade-in-delay-1">
                    <div class="section-label">Founder Note</div>
                    <h2 class="section-title">One founder, one studio, four lanes.</h2>
                    <p>Afia Labs was founded by Bridgette Owusu in 2024. The studio shipped a consumer iOS app first, then grew into client services, more apps, and a field guide. Founder-led from day one.</p>
                    <p>Every decision is made by a small team that cares about the work. Every line of code, every word of copy, every client engagement gets the same standard.</p>
                    <ul class="founder-values">
                        <li><span class="check">✓</span> Ownership-first</li>
                        <li><span class="check">✓</span> Useful over flashy</li>
                        <li><span class="check">✓</span> Personality is product</li>
                        <li><span class="check">✓</span> AI as leverage, not autopilot</li>
                        <li><span class="check">✓</span> Built with care for real people</li>
                    </ul>
                    <a href="/about/" class="founder-note-cta">Read the full studio story →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== FROM THE STUDIO (essay strip, now AFTER founder note) ========== -->
    {studioPosts.length > 0 && (
      <section id="studio-teaser" aria-label="From the Studio" class="studio-teaser-section">
        <div class="container">
          <div class="studio-teaser-header fade-in">
            <div class="studio-teaser-eyebrow">FROM THE STUDIO</div>
            <h2 class="studio-teaser-title">How we build, what we're learning.</h2>
            <p class="studio-teaser-sub">
              Founder notes, product lessons, and AI workflows from the build process.
            </p>
          </div>

          <div class="studio-teaser-grid">
            {studioPosts.map((p) => (
              <a href={`/studio/${p.id}/`} class="studio-teaser-card fade-in">
                <div class="studio-teaser-pillar">{STUDIO_PILLAR_LABELS[p.data.pillar]}</div>
                <h3 class="studio-teaser-card-title">{p.data.title}</h3>
                <div class="studio-teaser-meta">
                  {p.data.readingTime && <span>{p.data.readingTime} min</span>}
                  {p.data.readingTime && <span class="studio-teaser-dot">·</span>}
                  <span>{fmtStudioDate(p.data.date)}</span>
                </div>
              </a>
            ))}
          </div>

          <div class="studio-teaser-cta-wrap">
            <a href="/studio/" class="studio-teaser-cta">Read all studio notes →</a>
          </div>
        </div>
      </section>
    )}

    <!-- ========== FINAL ROUTING CTA (3-card decision band) ========== -->
    <section class="final-routing" aria-label="Where do you want to go next?">
        <div class="container">
            <div class="section-header fade-in">
                <h2 class="section-title">Where do you want to go next?</h2>
            </div>
            <div class="final-routing-grid fade-in">
                <a href="/services/" class="final-routing-card final-routing-primary">
                    <div class="final-routing-eyebrow">For small businesses</div>
                    <h3>I need a website</h3>
                    <p>Studio services for small businesses, founders, and creators.</p>
                    <span class="final-routing-arrow" aria-hidden="true">→</span>
                </a>
                <a href="/studio/" class="final-routing-card">
                    <div class="final-routing-eyebrow">For app curious</div>
                    <h3>I'm here for the apps</h3>
                    <p>MemeScanr, TripSquad, Planet Wonders, and more.</p>
                    <span class="final-routing-arrow" aria-hidden="true">→</span>
                </a>
                <a href="/book/" class="final-routing-card">
                    <div class="final-routing-eyebrow">For builders</div>
                    <h3>I want to learn to build</h3>
                    <p>From Idea to Income field guide and the AI App Builder Workbook.</p>
                    <span class="final-routing-arrow" aria-hidden="true">→</span>
                </a>
            </div>
        </div>
    </section>

    </main>
</BaseLayout>

<style>
  /* ========== STUDIO AT A GLANCE BAND ========== */
  .studio-glance {
    padding: 32px 0 12px;
    background: var(--bg-white);
    border-bottom: 1px solid var(--border-light);
  }
  .studio-glance-bar {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  .studio-glance-bar li {
    margin: 0;
  }
  .glance-chip {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 14px;
    background: rgba(124, 58, 237, 0.04);
    border: 1px solid rgba(124, 58, 237, 0.1);
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .glance-chip:hover {
    transform: translateY(-2px);
    border-color: rgba(124, 58, 237, 0.25);
    background: rgba(124, 58, 237, 0.07);
  }
  .glance-icon {
    font-size: 1.05rem;
    line-height: 1.2;
    flex-shrink: 0;
  }
  .glance-chip strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--purple-deep);
    letter-spacing: -0.005em;
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .glance-chip span:not(.glance-icon) {
    display: block;
    font-size: 0.74rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  @media (max-width: 1080px) {
    .studio-glance-bar {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 720px) {
    .studio-glance-bar {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .studio-glance-bar {
      grid-template-columns: 1fr;
    }
  }

  /* ========== WHAT WE DO ========== */
  .what-do-large-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
  }
  .what-do-large {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 36px;
