---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoonBanner from '../components/ComingSoonBanner.astro';
---

<BaseLayout>
    <main>
    <section class="hero" aria-label="Introduction">
        <div class="container hero-content">
            <div class="hero-text">
                <div class="hero-badge">
                    <span></span>
                    Independent App Studio
                </div>
                <h1>Building <span class="accent">delightful apps</span> that make everyday life easier.</h1>
                <p>Afia Labs creates smart, fun, and useful mobile experiences — from productivity tools like MemeScanr to educational adventures like Planet Wonders.</p>
                <div class="hero-buttons">
                    <a href="#apps" class="btn-primary">
                        Explore Our Apps
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <a href="https://form.jotform.com/260637441996064" target="_blank" rel="noopener noreferrer" class="btn-secondary">
                        Join Our Journey
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-illustration">
                    <div class="hero-glow"></div>
                    <div class="orbit-ring orbit-ring-1"></div>
                    <div class="orbit-ring orbit-ring-2"></div>

                    <div class="device-mockup device-phone">
                        <div class="device-phone-inner">
                            <div class="app-icon-large">⚡</div>
                            <div class="app-name">Afia Labs</div>
                            <div class="app-bar"><div class="app-bar-fill"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:40%"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:80%"></div></div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-1">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-purple-soft">🧹</div>
                            <div>
                                <div class="mini-label">Storage Cleaned</div>
                                <div class="mini-value">2.4 GB</div>
                            </div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-2">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-gold-soft">🌍</div>
                            <div>
                                <div class="mini-label">Countries</div>
                                <div class="mini-value">32 Explored</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="apps" aria-label="Our Apps">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Our Apps</div>
                <h2 class="section-title">Smart apps, built with care.</h2>
                <p class="section-subtitle">From cleaning up your camera roll to exploring the world — our apps are designed to be useful, beautiful, and fun.</p>
            </div>

            <div class="apps-grid">
                <div class="app-card memescanr fade-in fade-in-delay-1">
                    <div class="app-icon"><a href="https://memescanr.com" target="_blank" rel="noopener noreferrer"><img src="/memescanr_logo.png" alt="MemeScanr logo"></a></div>
                    <h3>MemeScanr</h3>
                    <p class="app-desc">A smart storage cleaner for iPhone that helps you reclaim space and organize your camera roll effortlessly.</p>
                    <div class="app-screenshots">
                        <img src="/image1.jpg" alt="MemeScanr Smart Scan feature" loading="lazy">
                        <img src="/image3.jpg" alt="MemeScanr Video Optimization feature" loading="lazy">
                    </div>
                    <ul class="app-features">
                        <li>
                            <span class="check">✓</span>
                            Detects duplicate photos and videos
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Compresses large media files
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Organizes clutter with smart categories
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Private "Backroom" storage for media and notes, protected by Face ID
                        </li>
                    </ul>
                    <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
                        <a href="https://apps.apple.com/us/app/memescanr-save-phone-storage/id6758227953" target="_blank" rel="noopener noreferrer" class="btn-app">
                            Get the App
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                        <a href="/memescanr/" style="font-size: 0.875rem; font-weight: 600; color: var(--purple-light); text-decoration: none;">
                            Learn more →
                        </a>
                    </div>
                    <div class="app-store-badge">
                        <a href="https://apps.apple.com/us/app/memescanr-save-phone-storage/id6758227953" target="_blank" rel="noopener noreferrer" aria-label="Download MemeScanr on the App Store">
                            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="40" viewBox="0 0 120 40"><rect width="120" height="40" rx="6" fill="#000"/><text x="60" y="15" text-anchor="middle" fill="#fff" font-family="Inter,-apple-system,sans-serif" font-size="7" font-weight="500">Download on the</text><text x="60" y="28" text-anchor="middle" fill="#fff" font-family="Inter,-apple-system,sans-serif" font-size="13" font-weight="700">App Store</text><path d="M25 10.5c-.14 0-1.87.02-3.12 1.54-.08.1-.15.2-.22.31.7-.26 1.55-.3 2.3.08.53.27.97.7 1.26 1.22.4-.18.76-.44 1.07-.78-.6-.67-1.04-1.57-1.29-2.37zm-1.56 3.56c-.67-.34-1.44-.34-2.11-.02-.47.22-.76.52-.96.77-.2.25-.34.5-.44.68l-.04.07c-.1.2-.2.42-.27.65-.18.6-.22 1.25-.08 1.86.13.56.4 1.08.79 1.52.38.43.87.74 1.4.88.37.1.75.1 1.12.02.29-.07.56-.2.82-.33.26-.13.53-.27.84-.3.31-.02.6.1.88.23.3.14.6.3.94.32.52.03 1.02-.2 1.4-.54.38-.35.64-.8.82-1.27l.02-.04c-.34-.17-.63-.42-.84-.73-.32-.46-.45-1.03-.36-1.58.08-.5.32-.97.68-1.32-.34-.4-.78-.71-1.27-.88-.56-.19-1.17-.17-1.72.04-.34.13-.64.32-.94.33-.3.01-.59-.15-.9-.28-.33-.13-.67-.22-1.02-.17-.2.03-.4.09-.58.18z" fill="#fff"/></svg>
                        </a>
                    </div>
                </div>

                <div class="app-card planetwonders fade-in fade-in-delay-2">
                    <div class="app-icon"><img src="/planet_wonders_launchscreen.png" alt="Planet Wonders logo"></div>
                    <h3>Planet Wonders <span class="coming-soon-tag">Coming Soon</span></h3>
                    <p class="app-desc">A kids' educational adventure app that sparks curiosity about cultures and countries around the world.</p>
                    <ul class="app-features">
                        <li>
                            <span class="check">✓</span>
                            Teaches cultures and countries through play
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Includes stories, coloring, and mini games
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Designed for kids ages 5–10
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Encourages creativity and curiosity
                        </li>
                    </ul>
                    <span class="btn-app" style="opacity:0.8; cursor:default;">
                        Coming Soon
                    </span>
                </div>

                <div class="app-card tripsquad fade-in fade-in-delay-2">
                    <div class="app-icon"><img src="/tripsquad_logo.png" alt="TripSquad logo"></div>
                    <h3>TripSquad <span class="coming-soon-tag">Coming Soon</span></h3>
                    <p class="app-desc">Group travel that actually happens. Invite the squad, vote on destinations, and let Scout — your AI companion — build the itinerary.</p>
                    <ul class="app-features">
                        <li>
                            <span class="check">✓</span>
                            Invite by @tag in-app, or share a link with anyone — no download needed
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Scout, your AI travel companion, suggests destinations the squad will love
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Vote together, reveal the destination, plan day-by-day
                        </li>
                        <li>
                            <span class="check">✓</span>
                            Built-in chat, packing list, and trip recap
                        </li>
                    </ul>
                    <span class="btn-app" style="opacity:0.85; cursor:default;">
                        Coming Soon
                    </span>
                </div>
            </div>
        </div>
    </section>

    <section id="explore-memescanr" aria-label="Explore MemeScanr" style="background: var(--bg-white); position: relative;">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Dive Deeper</div>
                <h2 class="section-title">Everything about MemeScanr.</h2>
                <p class="section-subtitle">Feature breakdowns, step-by-step iPhone cleanup guides, comparisons against every major cleaner, and long-form posts about the decisions behind the app.</p>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; max-width: 1100px; margin: 0 auto;">
                <a href="/memescanr/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">📱</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">What is MemeScanr?</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">The entity page. Full feature list, pricing, privacy stance, and how everything works.</p>
                </a>

                <a href="/memescanr/features/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">✨</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">Features</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">Memory Lane, Gallery Wrapped, Phone Therapist, Backroom vault, Boost, and more.</p>
                </a>

                <a href="/guides/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">📚</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">iPhone cleanup guides</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">Step-by-step how-tos. Delete duplicates, screenshots, memes. Compress videos. Fix full storage.</p>
                </a>

                <a href="/compare/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">⚖️</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">Comparisons</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">MemeScanr vs Gemini Photos, vs Apple\'s built-in album, vs cloud-based AI cleaners.</p>
                </a>

                <a href="/blog/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">📝</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">Blog</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">Design stories, privacy deep dives, real cleanup walkthroughs. Updated weekly.</p>
                </a>

                <a href="/memescanr/privacy/" style="display: block; background: var(--bg-light); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-xl)';" onmouseout="this.style.transform='';this.style.boxShadow='';">
                    <div style="font-size: 1.8rem; margin-bottom: 16px;">🔒</div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--purple-deep);">Privacy</h3>
                    <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6;">We literally don\'t have a server. What we don\'t collect, in plain English.</p>
                </a>
            </div>
        </div>
    </section>

    <ComingSoonBanner
      headline="From Idea to Income with AI Apps"
      subheadline="A book, a workbook, and a course for solo builders who want to ship real consumer apps with AI without becoming a passenger to it. By Bridgette Owusu, founder of Afia Labs."
      ctaText="Join the Waitlist"
      ctaHref="/book/"
    />

    <section id="about" aria-label="About Afia Labs">
        <div class="container">
            <div class="about-content">
                <div class="about-text fade-in">
                    <div class="section-label">About</div>
                    <h2 class="section-title">The story behind Afia Labs.</h2>
                    <p>Afia Labs is an independent software studio founded by Bridgette Owusu — building thoughtful consumer apps for modern life.</p>
                    <p>She built her first app solo, using AI tools, and shipped it to the App Store under her own name. That experience shaped everything Afia Labs stands for.</p>
                    <p>Every product we make is built on three beliefs: people deserve ownership over their digital lives, software should have personality, and useful things should still feel good to use.</p>
                    <p>The vision is simple: build real products, stay in control, and inspire the next generation of builders.</p>
                </div>
                <div class="about-visual fade-in fade-in-delay-1">
                    <img src="/founder.jpg" alt="Bridgette Owusu, founder of Afia Labs" class="founder-photo" loading="lazy">
                </div>
            </div>
        </div>
    </section>

    <section id="mission" aria-label="Our Mission">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Our Mission</div>
                <h2 class="section-title">What drives us forward.</h2>
                <p class="section-subtitle">Every app we build is guided by three core principles.</p>
            </div>

            <div class="mission-grid">
                <div class="mission-card fade-in fade-in-delay-1">
                    <div class="mission-icon">🛠️</div>
                    <h3>Build Useful Tools</h3>
                    <p>We create apps that solve real problems, tools that save time, reduce friction, and genuinely help people in their day-to-day lives.</p>
                </div>
                <div class="mission-card fade-in fade-in-delay-2">
                    <div class="mission-icon">✨</div>
                    <h3>Make Technology Fun</h3>
                    <p>Great software should feel delightful. We design experiences that are not only functional but enjoyable and beautiful to use.</p>
                </div>
                <div class="mission-card fade-in fade-in-delay-3">
                    <div class="mission-icon">💜</div>
                    <h3>Inspire the Next Generation</h3>
                    <p>We believe technology can spark curiosity and open doors. Our work is a love letter to the future, and to the children who will shape it.</p>
                </div>
            </div>
        </div>
    </section>
    </main>
</BaseLayout>
