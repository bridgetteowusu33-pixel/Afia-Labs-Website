---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoonBanner from '../components/ComingSoonBanner.astro';
import { getCollection } from 'astro:content';

// Pull the 3 most-recent published Studio essays for the homepage strip.
const studioPosts = (
  await getCollection('studio', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const STUDIO_PILLAR_LABELS: Record<string, string> = {
  'building-with-ai': 'Building with AI',
  'indie-economics': 'Indie Economics',
  'studio-philosophy': 'Studio Philosophy',
  'launch-notes': 'Launch Notes',
  'the-craft': 'The Craft',
};

function fmtStudioDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<BaseLayout>
    <main>
    <section class="hero" aria-label="Introduction">
        <div class="container hero-content">
            <div class="hero-text">
                <div class="hero-badge">
                    <span></span>
                    Independent Product Studio
                </div>
                <h1>Afia Labs builds useful <span class="accent">apps, AI-assisted tools, and digital systems</span> with personality and purpose.</h1>
                <p>We create consumer apps, small-business web systems, and practical field guides for people building, organizing, learning, and growing with technology.</p>
                <div class="hero-buttons">
                    <a href="/studio/" class="btn-primary">
                        Explore the Studio
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <a href="/services/" class="btn-secondary">
                        Work With Us
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-illustration">
                    <div class="hero-glow"></div>
                    <div class="orbit-ring orbit-ring-1"></div>
                    <div class="orbit-ring orbit-ring-2"></div>

                    <div class="device-mockup device-phone">
                        <div class="device-phone-inner">
                            <div class="app-icon-large">⚡</div>
                            <div class="app-name">Afia Labs</div>
                            <div class="app-bar"><div class="app-bar-fill"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:40%"></div></div>
                            <div class="app-bar" style="margin-top:-4px"><div class="app-bar-fill" style="width:80%"></div></div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-1">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-purple-soft">📱</div>
                            <div>
                                <div class="mini-label">Apps</div>
                                <div class="mini-value mini-value-compact">MemeScanr · TripSquad</div>
                            </div>
                        </div>
                    </div>

                    <div class="device-mockup device-card-2">
                        <div class="mini-card-inner">
                            <div class="mini-icon bg-gold-soft">🛠️</div>
                            <div>
                                <div class="mini-label">Studio Services</div>
                                <div class="mini-value mini-value-compact">Websites · Apps</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="what-we-build" aria-label="What We Build">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">What We Build</div>
                <h2 class="section-title">Four ways the studio shows up.</h2>
                <p class="section-subtitle">Afia Labs creates useful digital products across consumer apps, small-business systems, and practical builder education.</p>
            </div>

            <div class="what-grid">
                <div class="what-card fade-in fade-in-delay-1">
                    <div class="what-card-icon">📱</div>
                    <h3>Consumer Apps</h3>
                    <p>Privacy-first, personality-rich apps for everyday life. From photo cleanup to group travel and playful learning.</p>
                    <a href="/studio/" class="what-card-cta">Explore products →</a>
                </div>
                <div class="what-card fade-in fade-in-delay-2">
                    <div class="what-card-icon">🛠️</div>
                    <h3>Studio Services</h3>
                    <p>Websites, landing pages, and simple digital systems for small businesses, creators, and founders.</p>
                    <a href="/services/" class="what-card-cta">Work with us →</a>
                </div>
                <div class="what-card fade-in fade-in-delay-2">
                    <div class="what-card-icon">📖</div>
                    <h3>Field Guides</h3>
                    <p>Practical books, workbooks, and resources for builders learning how to use AI without losing control of the process.</p>
                    <a href="/book/" class="what-card-cta">Read the book →</a>
                </div>
                <div class="what-card fade-in fade-in-delay-3">
                    <div class="what-card-icon">📝</div>
                    <h3>Studio Notes</h3>
                    <p>Founder notes, product lessons, AI workflows, and behind-the-scenes thinking from the Afia Labs build process.</p>
                    <a href="/blog/" class="what-card-cta">Read the latest →</a>
                </div>
            </div>
        </div>
    </section>

    <section id="apps" aria-label="Featured Products">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Featured Products</div>
                <h2 class="section-title">Featured products.</h2>
                <p class="section-subtitle">A look at the apps and tools being built inside Afia Labs.</p>
            </div>

            <div class="apps-grid">
                <div class="app-card memescanr fade-in fade-in-delay-1">
                    <div class="app-icon"><img src="/memescanr_logo.png" alt="MemeScanr logo"></div>
                    <h3>MemeScanr <span class="status-badge status-live">Live</span></h3>
                    <p class="app-desc">A privacy-first iPhone gallery cleaner that helps people reclaim storage with personality. On-device duplicate, screenshot, meme, and blur detection.</p>
                    <a href="/memescanr/" class="btn-app">
                        Explore MemeScanr
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="app-card tripsquad fade-in fade-in-delay-2">
                    <div class="app-icon"><img src="/tripsquad_logo.png" alt="TripSquad logo"></div>
                    <h3>TripSquad <span class="status-badge status-live">Live</span></h3>
                    <p class="app-desc">The group-trip planner for the whole squad. Built to help friends agree, vote, reveal, and actually take the trip.</p>
                    <a href="/tripsquad/" class="btn-app">
                        Explore TripSquad
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="app-card planetwonders fade-in fade-in-delay-3">
                    <div class="app-icon"><img src="/planet_wonders_launchscreen.png" alt="Planet Wonders logo"></div>
                    <h3>Planet Wonders <span class="status-badge status-dev">In Development</span></h3>
                    <p class="app-desc">A playful world-learning app for kids, designed around creativity, curiosity, and global exploration.</p>
                    <a href="/studio/#planet-wonders" class="btn-app">
                        Explore Planet Wonders
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section id="work-with-us" aria-label="Work With Afia Labs" style="background: var(--bg-white); position: relative;">
        <div class="container">
            <div class="section-header fade-in">
                <div class="section-label">Work With Us</div>
                <h2 class="section-title">Work with Afia Labs.</h2>
                <p class="section-subtitle">Need a website, landing page, or digital system that makes your business look serious online? Afia Labs brings product thinking, clean design, and conversion-focused structure to small businesses, creators, and founders.</p>
            </div>

            <div class="what-grid" style="grid-template-columns: repeat(3, 1fr);">
                <div class="what-card fade-in fade-in-delay-1">
                    <div class="what-card-icon">🔒</div>
                    <h3>Websites that build trust</h3>
                    <p>Clean, mobile-friendly websites that help customers understand who you are, what you offer, and how to take the next step.</p>
                </div>
                <div class="what-card fade-in fade-in-delay-2">
                    <div class="what-card-icon">🎯</div>
                    <h3>Landing pages that sell the offer</h3>
                    <p>Focused pages for launches, services, books, products, waitlists, and campaigns.</p>
                </div>
                <div class="what-card fade-in fade-in-delay-3">
                    <div class="what-card-icon">⚙️</div>
                    <h3>Simple digital systems</h3>
                    <p>Forms, intake flows, automation-ready content, and lightweight systems that make the business easier to run.</p>
                </div>
            </div>

            <div class="work-cta-wrap fade-in">
                <a href="/services/#contact" class="btn-primary">
                    Start a Project
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
        </div>
    </section>

    <ComingSoonBanner
      eyebrow="Field Guide № 1"
      headline="Build with AI. Stay in control. Own the outcome."
      subheadline="Afia Labs Field Guides turn real product-building lessons into practical resources for founders, creators, and solo builders."
      ctaText="Explore the book"
      ctaHref="/book/"
    />

    {studioPosts.length > 0 && (
      <section id="studio-teaser" aria-label="From the Studio" class="studio-teaser-section">
        <div class="container">
          <div class="studio-teaser-header fade-in">
            <div class="studio-teaser-eyebrow">FROM THE STUDIO</div>
            <h2 class="studio-teaser-title">How we build, what we're learning.</h2>
            <p class="studio-teaser-sub">
              Founder notes, product lessons, AI workflows, and behind-the-scenes
              thinking from the Afia Labs build process.
            </p>
          </div>

          <div class="studio-teaser-grid">
            {studioPosts.map((p) => (
              <a href={`/studio/${p.id}/`} class="studio-teaser-card fade-in">
                <div class="studio-teaser-pillar">{STUDIO_PILLAR_LABELS[p.data.pillar]}</div>
                <h3 class="studio-teaser-card-title">{p.data.title}</h3>
                <div class="studio-teaser-meta">
                  {p.data.readingTime && <span>{p.data.readingTime} min</span>}
                  {p.data.readingTime && <span class="studio-teaser-dot">·</span>}
                  <span>{fmtStudioDate(p.data.date)}</span>
                </div>
              </a>
            ))}
          </div>

          <div class="studio-teaser-cta-wrap">
            <a href="/studio/" class="studio-teaser-cta">Read all studio notes →</a>
          </div>
        </div>
      </section>
    )}

    <section id="about" aria-label="About Afia Labs">
        <div class="container">
            <div class="about-content">
                <div class="about-text fade-in">
                    <div class="section-label">About</div>
                    <h2 class="section-title">An independent product studio.</h2>
                    <p>Afia Labs was founded by Bridgette Owusu as an independent product studio for building useful technology with intention. What started with a shipped iPhone app has grown into a studio ecosystem of consumer apps, AI-assisted tools, small-business digital systems, and practical guides for people who want to build with more ownership.</p>
                    <ul class="about-values">
                        <li><span class="check">✓</span> Ownership-first</li>
                        <li><span class="check">✓</span> Useful over flashy</li>
                        <li><span class="check">✓</span> Personality is product</li>
                        <li><span class="check">✓</span> AI as leverage, not autopilot</li>
                        <li><span class="check">✓</span> Built with care for real people</li>
                    </ul>
                </div>
                <div class="about-visual fade-in fade-in-delay-1">
                    <img src="/founder.jpg" alt="Bridgette Owusu, founder of Afia Labs" class="founder-photo" loading="lazy">
                </div>
            </div>
        </div>
    </section>
    </main>
</BaseLayout>

<style>
  /* From the Studio — homepage editorial strip */
  .studio-teaser-section {
    padding: 96px 0;
    background: var(--bg-light, #faf9fc);
    border-top: 1px solid var(--border-light, rgba(124, 58, 237, 0.08));
    border-bottom: 1px solid var(--border-light, rgba(124, 58, 237, 0.08));
  }
  .studio-teaser-header {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .studio-teaser-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.32em;
    color: var(--purple-light, #7c3aed);
    margin-bottom: 18px;
  }
  .studio-teaser-title {
    font-family: var(--font-heading, "Inter"), sans-serif;
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text-primary, #1a0a2e);
    margin: 0 0 16px;
  }
  .studio-teaser-sub {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary, #5b5675);
    max-width: 620px;
  }
  .studio-teaser-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 48px;
  }
  .studio-teaser-card {
    display: flex;
    flex-direction: column;
    padding: 28px 0 32px;
    border-top: 1px solid var(--border-light, rgba(124, 58, 237, 0.16));
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease;
  }
  .studio-teaser-card:hover { transform: translateY(-2px); }
  .studio-teaser-pillar {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--purple-light, #7c3aed);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .studio-teaser-card-title {
    font-family: var(--font-heading, "Inter"), sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--text-primary, #1a0a2e);
    margin: 0 0 18px;
    flex-grow: 1;
  }
  .studio-teaser-card:hover .studio-teaser-card-title {
    color: var(--purple-light, #7c3aed);
  }
  .studio-teaser-meta {
    font-size: 12px;
    color: var(--text-muted, #8e87a0);
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .studio-teaser-dot { color: var(--text-muted, #8e87a0); }
  .studio-teaser-cta-wrap {
    border-top: 1px solid var(--border-light, rgba(124, 58, 237, 0.08));
    padding-top: 32px;
  }
  .studio-teaser-cta {
    font-size: 15px;
    font-weight: 600;
    color: var(--purple-light, #7c3aed);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .studio-teaser-cta:hover { color: var(--purple-deep, #1a0a2e); }

  @media (max-width: 880px) {
    .studio-teaser-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .studio-teaser-card { padding: 24px 0; }
  }
  @media (max-width: 640px) {
    .studio-teaser-section { padding: 64px 0; }
    .studio-teaser-header { margin-bottom: 40px; }
  }

  /* Work With Us CTA wrapper */
  .work-cta-wrap {
    margin-top: 40px;
    text-align: center;
  }

  /* Hero floating cards: longer brand-pillar labels need a smaller font to fit */
  .mini-value-compact {
    font-size: 0.78rem !important;
    line-height: 1.25 !important;
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  /* About values list */
  .about-values {
    list-style: none;
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
  }
  .about-values li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .about-values .check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    margin-top: 1px;
    background: rgba(124, 58, 237, 0.08);
    color: var(--purple-light);
  }

  /* Status badge spacing inside featured product H3 */
  .app-card h3 .status-badge {
    margin-left: 8px;
    vertical-align: middle;
  }

  /* Work With Us mini cards adapt to 1-col on small screens */
  @media (max-width: 880px) {
    section#work-with-us .what-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
