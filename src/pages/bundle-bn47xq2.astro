---
import BaseLayout from '../layouts/BaseLayout.astro';
import PreLaunchHero from '../components/PreLaunchHero.astro';
import '../styles/pre-launch.css';

const waitlistUrl = 'https://form.jotform.com/261045381980054';
const accent = '#d9a3ff'; // soft lilac bridges gold + pink + violet

const title = 'The Full Bundle — Afia Labs';
const description =
  'Book. Workbook. Course. The complete ownership-first learning system for building AI apps. By Bridgette Owusu.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="pre-main pre-main-bundle" style={`--accent: ${accent};`}>
    <PreLaunchHero
      eyebrow="4 of 4 · The Full Bundle"
      accentColor={accent}
      headline="Book. Workbook. Course. All three."
      subhead="The complete Afia Labs system for building AI apps with ownership. Belief, clarity, and execution in one bundle."
      primaryCtaText="Join the Waitlist"
      primaryCtaHref={waitlistUrl}
      secondaryCtaText="See What's Inside →"
      secondaryCtaHref="#trio"
    />

    <!-- ========== THE PITCH ========== -->
    <section class="pre-section pre-section-pitch">
      <div class="container">
        <div class="pre-tri-bar" aria-hidden="true"><span></span><span></span><span></span></div>
        <div class="pre-eyebrow">The Pitch</div>
        <div class="pre-pitch-body">
          <p class="pre-pitch-lead">
            This is bigger than a book. It's the full Afia Labs system for turning an idea into a shipped, owned, real product — without becoming a passenger to the AI tools you use along the way.
          </p>
          <p>
            The book gives you the belief. The workbook gives you the clarity. The course gives you the execution. Together they're designed to take a solo builder from the Tuesday they had the idea to the Tuesday the app goes live in the App Store.
          </p>
          <p>
            You can buy each piece alone and it'll still work. But they're built to fit together. Each one reinforces the others. Each one makes the others sharper.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== THE THREE-PART SYSTEM ========== -->
    <section id="trio" class="pre-section">
      <div class="container">
        <div class="pre-eyebrow">The Three-Part System</div>
        <h2 class="pre-section-title">Three products. One path.</h2>
        <p class="pre-section-sub">Each piece does one job. Together they take you from the idea to the ship.</p>
        <div class="pre-trio-grid">
          <div class="pre-trio-card pre-trio-card-book">
            <div class="pre-trio-label">01 · The Book</div>
            <h3>Belief</h3>
            <p class="pre-trio-tag">From Idea to Income with AI Apps</p>
            <p>Nineteen chapters. The honest field guide. The story, the scars, the frameworks behind every shipped decision.</p>
          </div>
          <div class="pre-trio-card pre-trio-card-workbook">
            <div class="pre-trio-label">02 · The Workbook</div>
            <h3>Clarity</h3>
            <p class="pre-trio-tag">The AI App Builder Workbook</p>
            <p>Eighty-eight pages. Eleven sections. Where thinking becomes doing and vague ideas become commitments.</p>
          </div>
          <div class="pre-trio-card pre-trio-card-course">
            <div class="pre-trio-label">03 · The Course</div>
            <h3>Execution</h3>
            <p class="pre-trio-tag">From Idea to Income: The Course</p>
            <p>Eleven video modules. Templates, prompts, audits. The walking-beside-you execution layer.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WHO IT'S FOR ========== -->
    <section class="pre-section">
      <div class="container">
        <div class="pre-eyebrow">Who It's For</div>
        <h2 class="pre-section-title">For the builder who keeps almost starting.</h2>
        <div class="pre-audience-grid">
          <div class="pre-audience-card">
            <div class="pre-audience-icon">01</div>
            <h3>The Builder Who Keeps Almost Starting</h3>
            <p>The one with a notes app full of ideas and zero shipped products.</p>
          </div>
          <div class="pre-audience-card">
            <div class="pre-audience-icon">02</div>
            <h3>The First-Time Solo Founder</h3>
            <p>Building under her own name, no cofounder, no VC, no permission.</p>
          </div>
          <div class="pre-audience-card">
            <div class="pre-audience-icon">03</div>
            <h3>The Master Driver in Training</h3>
            <p>Who wants to use AI without becoming a passenger to it.</p>
          </div>
          <div class="pre-audience-card">
            <div class="pre-audience-icon">04</div>
            <h3>The Honest Builder</h3>
            <p>Who wants the real story, the scars, and the receipts — not the highlight reel.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WHAT YOU GET ========== -->
    <section class="pre-section">
      <div class="container">
        <div class="pre-eyebrow">What You Get</div>
        <h2 class="pre-section-title">Everything. All of it.</h2>
        <ul class="pre-list">
          <li><div class="pre-list-num">01</div><div class="pre-list-body"><strong>The full book</strong><span>19 chapters, 3 appendices, 50k+ words, 12 MemeScanr case studies.</span></div></li>
          <li><div class="pre-list-num">02</div><div class="pre-list-body"><strong>The full workbook</strong><span>88 pages, 11 sections, 5 worksheets, paired 1:1 with every chapter.</span></div></li>
          <li><div class="pre-list-num">03</div><div class="pre-list-body"><strong>The full course</strong><span>11 pre-recorded video modules and every exercise that goes with them.</span></div></li>
          <li><div class="pre-list-num">04</div><div class="pre-list-body"><strong>Reusable prompt pack</strong><span>15 prompts you can drop into any AI tool and get real answers back.</span></div></li>
          <li><div class="pre-list-num">05</div><div class="pre-list-body"><strong>Pre-submission audit</strong><span>The 25-item checklist that gets your app past the first reviewer.</span></div></li>
          <li><div class="pre-list-num">06</div><div class="pre-list-body"><strong>Launch audit prompt</strong><span>One prompt that reads your whole app before you hit submit.</span></div></li>
          <li><div class="pre-list-num">07</div><div class="pre-list-body"><strong>Session log templates</strong><span>The daily rhythm tools I used to ship MemeScanr solo.</span></div></li>
          <li><div class="pre-list-num">08</div><div class="pre-list-body"><strong>Early access pricing</strong><span>Waitlist subscribers get first dibs and the best price on launch.</span></div></li>
        </ul>
      </div>
    </section>

    <!-- ========== TIER HINT ========== -->
    <section class="pre-section">
      <div class="container">
        <div class="pre-eyebrow">The Offer</div>
        <h2 class="pre-section-title">Three tiers. You pick your entry point.</h2>
        <div class="pre-tiers">
          <div class="pre-tier">
            <p class="pre-tier-name">Basic</p>
            <h3>The Book</h3>
            <p>Everything you need to build the belief. Read it once. Keep it forever.</p>
          </div>
          <div class="pre-tier">
            <p class="pre-tier-name">Standard</p>
            <h3>Book + Workbook</h3>
            <p>For the builder who wants the frameworks and the exercises to use them.</p>
          </div>
          <div class="pre-tier">
            <p class="pre-tier-name">Premium</p>
            <h3>Book + Workbook + Course</h3>
            <p>The full execution system. Everything, walked through beside you.</p>
          </div>
        </div>
        <p class="pre-tier-note">Final pricing announced at launch. Waitlist subscribers get early access pricing.</p>
      </div>
    </section>

    <!-- ========== PULL QUOTE ========== -->
    <section class="pre-section pre-section-quote">
      <div class="container">
        <div class="pre-quote-mark" aria-hidden="true">"</div>
        <blockquote class="pre-quote-text">
          Built with AI. Stayed in control. Owned the outcome.
        </blockquote>
        <div class="pre-quote-cite">— The Afia Labs promise</div>
      </div>
    </section>

    <!-- ========== WAITLIST CTA ========== -->
    <section class="pre-section pre-section-cta">
      <div class="container">
        <div class="pre-cta-card">
          <h2>Be first in line when it ships.</h2>
          <p>Join the waitlist and I'll email you the moment the bundle is ready. Waitlist subscribers get early access pricing on all three tiers.</p>
          <a href={waitlistUrl} target="_blank" rel="noopener noreferrer" class="pre-cta-button">
            Join the Waitlist
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <p class="pre-cta-meta">Built with AI. Stayed in control. Owned the outcome.</p>
        </div>
      </div>
    </section>

    <!-- ========== EXPLORE EACH PIECE ========== -->
    <section class="pre-section">
      <div class="container">
        <div class="pre-eyebrow">Explore Each Piece</div>
        <h2 class="pre-section-title">Or start with one.</h2>
        <div class="pre-explore-grid">
          <a href="/book-b8k29fx/" class="pre-explore-card" style="--explore-accent: #f59e0b;">
            <div class="pre-explore-num">01</div>
            <h3>The Book</h3>
            <p>The honest field guide. Nineteen chapters. The story behind every framework.</p>
            <div class="pre-explore-arrow">→</div>
          </a>
          <a href="/workbook-wk93a2n/" class="pre-explore-card" style="--explore-accent: #ec4899;">
            <div class="pre-explore-num">02</div>
            <h3>The Workbook</h3>
            <p>Where thinking becomes doing. 88 pages of prompts and decision tools.</p>
            <div class="pre-explore-arrow">→</div>
          </a>
          <a href="/course-cr48jp7/" class="pre-explore-card" style="--explore-accent: #a78bfa;">
            <div class="pre-explore-num">03</div>
            <h3>The Course</h3>
            <p>The execution layer. Eleven modules that walk you through the whole thing.</p>
            <div class="pre-explore-arrow">→</div>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <section class="pre-section-footer">
      <div class="container">
        <p>Afia Labs · Built with AI. Stayed in control. Owned the outcome.</p>
      </div>
    </section>
  </main>
</BaseLayout>
