---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Leave a review for Afia Labs Studio';
const description =
  'Thanks for working with Afia Labs Studio. Leave a quick review on Google to help other small businesses, creators, and founders find the studio when they search for help with their websites.';

const breadcrumbsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://afialabs.net/' },
    { '@type': 'ListItem', position: 2, name: 'Leave a review', item: 'https://afialabs.net/review/' },
  ],
};
---

<BaseLayout title={title} description={description} canonical="https://afialabs.net/review/" ogType="website" noindex={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbsJsonLd)} />

  <main>
    <section class="hero subpage-hero" aria-label="Leave a review intro">
      <div class="container">
        <div class="hero-badge">
          <span></span>
          Thank you · 30 seconds
        </div>
        <h1>Leave a review for Afia Labs Studio.</h1>
        <p class="subpage-lede">
          Thanks for working with us. A quick review on Google helps other small businesses, creators, and founders find the studio when they search for help with their websites or apps. It takes about 30 seconds and means a lot.
        </p>
        <div class="hero-buttons">
          <a href="https://g.page/r/CRL7lWvgmT0ZEBI/review" target="_blank" rel="noopener noreferrer" class="btn-primary">
            ⭐ Leave a 5-star review on Google
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a href="mailto:support@afialabs.net?subject=Feedback%20for%20Afia%20Labs%20Studio" class="btn-secondary">
            Or email feedback directly
          </a>
        </div>
        <p class="review-fine-print">
          Reviews are public on Google. You'll be asked to sign in with your Google account. Honest feedback only, please.
        </p>
      </div>
    </section>

    <section class="subpage-band">
      <div class="container subpage-prose">
        <h2>What helps the most in a review.</h2>
        <p>
          You can skip this and just leave whatever feels right. If you want a starting point:
        </p>
        <ul class="subpage-checklist">
          <li><strong>What you hired us to do.</strong> A new website? A landing page? A booking flow? Specifics help future clients picture themselves in the same project.</li>
          <li><strong>What working together was like.</strong> Communication, responsiveness, what the kickoff and revision rounds felt like.</li>
          <li><strong>The result.</strong> A line about the finished site and whether it has helped your business in the ways you wanted.</li>
        </ul>
        <p>
          Two or three sentences is plenty. Reviews do not need to be long to be useful.
        </p>

        <h2>Why reviews matter (the honest version).</h2>
        <p>
          For a small product studio, Google reviews are the single biggest local-SEO signal. Search ranking for "website designer Virginia" and similar local queries is driven heavily by review count, recency, and rating. Every honest review moves the studio up the ranking for those searches, which means more small businesses find us when they need help.
        </p>
        <p>
          We do not pay for reviews and we do not write them ourselves. Everything on our profile is from a real client. Thank you for being one of them.
        </p>

        <div class="subpage-cta-card">
          <h2>Ready when you are.</h2>
          <p>One click opens the Google review form. Sign in, leave a quick note, done.</p>
          <a href="https://g.page/r/CRL7lWvgmT0ZEBI/review" target="_blank" rel="noopener noreferrer" class="btn-primary">⭐ Leave a 5-star review on Google</a>
        </div>

        <h2>Related</h2>
        <ul class="subpage-related">
          <li><a href="/services/">Studio services</a></li>
          <li><a href="https://glambycella.com" target="_blank" rel="noopener noreferrer">Recent client work: Glam by Cella</a></li>
          <li><a href="/services/#contact">Start another project</a></li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .review-fine-print {
    margin: 20px 0 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 560px;
  }
</style>
