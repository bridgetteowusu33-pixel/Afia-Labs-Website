---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AppStoreCTA from '../../components/AppStoreCTA.astro';

const title = 'Afia Labs blog — small business, websites, and product notes';
const description =
  'Long-form posts from Afia Labs Studio. Small-business websites and local SEO, product design from MemeScanr and TripSquad, founder notes on building with AI.';
const heading = 'The Afia Labs blog';
const lede =
  'Long-form posts from Afia Labs Studio. Small-business website and local SEO writing for founders, design and privacy stories from MemeScanr, and notes on building consumer apps with AI as leverage. Follow the RSS feed for updates.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog' },
];

const posts = [
  { href: '/blog/why-group-trips-fall-apart/', date: '2026-05-06', title: 'Why group trips fall apart', blurb: 'Most group trips never happen, and the reason is not the destination. It is the social design of group decisions. What actually breaks group trips and what to do about it.', tag: 'Group Travel · Story' },
  { href: '/blog/scout-the-ai-travel-companion/', date: '2026-05-06', title: 'Scout, the AI travel companion inside TripSquad', blurb: 'Scout is the AI feature inside TripSquad. Unlike generic travel chatbots, Scout knows what your group has voted on and what kind of trip the squad is shaping. Here is how it works and why it is different.', tag: 'Group Travel · Feature' },
  { href: '/blog/getting-friends-to-actually-commit-to-the-trip/', date: '2026-05-06', title: 'Getting friends to actually commit to the trip', blurb: 'Every group trip has the same hinge moment: converting "yes, I want to go" into "yes, I am committed." The four moves that get the trip from hypothetical to real.', tag: 'Group Travel · Strategy' },
  { href: '/blog/the-reveal-mechanic-why-it-works/', date: '2026-05-06', title: 'The reveal mechanic, and why it works', blurb: 'TripSquad reveals the winning destination after voting closes, all at once. The reveal feels like a small thing. It is the most important social-design choice in the app.', tag: 'Group Travel · Design Story' },
  { href: '/blog/small-business-website-cost-virginia/', date: '2026-05-05', title: 'How much does a small business website cost in Virginia?', blurb: 'A direct tier-by-tier breakdown for Virginia: DIY builders, freelancers, studios, and agencies. What you pay, what you get, which one fits.', tag: 'Small Business' },
  { href: '/blog/local-service-business-website-checklist/', date: '2026-05-05', title: 'What every local service business website needs before launch', blurb: 'The 12-item pre-launch checklist for local service business websites, ordered by what moves the needle most.', tag: 'Small Business' },
  { href: '/blog/instagram-not-enough-local-business/', date: '2026-05-05', title: 'Why Instagram is not enough for local beauty and service businesses', blurb: 'Instagram is great for showing the work. It is also a rented audience and not built to convert. The four problems with Instagram-only.', tag: 'Small Business' },
  { href: '/blog/booking-ready-website-helps-small-businesses/', date: '2026-05-05', title: 'How a booking-ready website helps small businesses get more clients', blurb: 'What booking-ready actually means, why it changes the economics of a small service business, and the simple setup that ships in a week.', tag: 'Small Business' },
  { href: '/blog/website-checklist-virginia-small-businesses/', date: '2026-05-05', title: 'Website checklist for Virginia small businesses', blurb: 'The 18-item practical, Virginia-specific website checklist for small business owners. Ordered by what to do first.', tag: 'Small Business' },
  { href: '/blog/gallery-wrapped-2026-what-personality-are-you/', date: '2026-04-01', title: 'Gallery Wrapped 2026 — which gallery personality are you?', blurb: 'Gallery Wrapped is live for April. Eight personality types, nine cards, one monthly reveal. Here\'s what each personality means.', tag: 'Launch post' },
  { href: '/blog/the-privacy-problem-with-ai-photo-cleaners/', date: '2026-04-02', title: 'The privacy problem with "AI-powered" iPhone photo cleaners', blurb: 'Most cleaner apps that advertise "AI-powered" cleanup upload your photos to third-party servers. Here\'s the trade nobody explains and how to verify which camp an app is in.', tag: 'Privacy' },
  { href: '/blog/how-i-freed-20gb-on-my-iphone-in-10-minutes/', date: '2026-03-30', title: 'How I freed 20 GB on my iPhone in 10 minutes', blurb: 'A real cleanup session in ten minutes of active work. The sequence, the tools, and why most of the wins came from compression, not deletion.', tag: 'Story' },
  { href: '/blog/i-had-10000-photos-heres-how-i-cleaned-my-iphone/', date: '2026-03-25', title: 'I had 10,000 photos — here\'s how I cleaned my iPhone', blurb: 'A real 10,000-photo cleanup walkthrough. What the scan found, what I actually kept, and how much storage came back — category by category.', tag: 'Story' },
  { href: '/blog/tinder-for-your-camera-roll/', date: '2026-03-18', title: 'Tinder for your camera roll — the Memory Lane origin story', blurb: 'The grid was the problem. Why we built Memory Lane as a Tinder-style swipe review for every photo you\'ve ever taken.', tag: 'Design story' },
  { href: '/blog/your-phone-needs-therapy/', date: '2026-03-10', title: 'Your phone needs therapy — the Phone Therapist origin story', blurb: 'Cleaner apps are joyless by default. Why we built a daily diagnosis feature that names your camera roll behavior with humor instead of guilt.', tag: 'Design story' },
  { href: '/blog/why-your-iphone-storage-is-always-full/', date: '2026-03-05', title: 'Why your iPhone storage is always full', blurb: 'iOS does not clean itself. Here\'s what\'s actually eating your storage and why "delete some photos" never fixes it.', tag: 'Explainer' },
  { href: '/blog/seasonal-icons-why-we-built-them/', date: '2026-03-01', title: 'Why MemeScanr ships seasonal app icons', blurb: 'Seven app icons that switch automatically with the seasons. Tiny feature, outsized value for retention and Apple editorial.', tag: 'Design story' },
  { href: '/blog/the-decoy-vault-explained/', date: '2026-02-22', title: 'The decoy vault, explained', blurb: 'How Backroom fools snoopers with a believable fake library on wrong PIN entry, and why no other cleaner ships this.', tag: 'Security' },
];
---

<ArticleLayout
  title={title}
  description={description}
  eyebrow="Blog"
  heading={heading}
  lede={lede}
  breadcrumbs={breadcrumbs}
  canonical="https://afialabs.net/blog/"
  ogType="website"
>
  <p>
    <a href="/blog/subscribe/">Subscribe via RSS →</a>
  </p>

  {posts.map((p) => (
    <article style="padding: 28px 0; border-bottom: 1px solid var(--border-light);">
      <div style="display: flex; gap: 12px; font-size: 0.78rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">
        <span>{new Date(p.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        <span>·</span>
        <span>{p.tag}</span>
      </div>
      <h2 style="margin-top: 0 !important; margin-bottom: 8px !important;"><a href={p.href} style="text-decoration: none; color: var(--purple-deep);">{p.title}</a></h2>
      <p style="margin-bottom: 0;">{p.blurb}</p>
    </article>
  ))}

  <AppStoreCTA />
</ArticleLayout>
