---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = 'Work With Afia Labs — Websites, Landing Pages & Digital Systems';
const description =
  'Afia Labs builds polished websites, landing pages, and simple digital systems for small businesses, creators, and founders who want to look professional online.';

const servicesFaq = [
  {
    q: 'How much does a website from Afia Labs cost?',
    a: 'Launch Pages start at $750. Business Websites start at $2,000. Growth Systems are custom-quoted based on scope. Final pricing depends on the number of pages, integrations, content needs, timeline, and revision rounds.',
  },
  {
    q: 'How long does a typical project take?',
    a: 'Launch Pages typically ship in 1 to 2 weeks. Business Websites usually take 3 to 5 weeks. Growth Systems vary by scope and integrations. Every project starts with a short kickoff call so we agree on the timeline up front.',
  },
  {
    q: 'What platform do you build on (Webflow, WordPress, custom)?',
    a: 'We pick the right tool for the brief. Most small-business sites are built as fast static sites (Astro) or on a no-code platform like Webflow when easy in-house editing matters more than custom logic. We do not default to WordPress, but we will use it when it fits the team.',
  },
  {
    q: 'Do you work with clients outside the US?',
    a: 'Yes. Most communication is async via email and Loom. Calls happen on Google Meet. We have worked with founders and small businesses across multiple time zones.',
  },
  {
    q: "What's included in the Launch Page package?",
    a: 'A polished one-page responsive website, mobile-first design, a clear CTA section, a working contact form, basic SEO setup (titles, descriptions, sitemap), and one revision round. The brief covers your goals, your audience, and the single action you most want visitors to take.',
  },
  {
    q: 'Do you offer ongoing maintenance after launch?',
    a: 'Maintenance is not bundled into project pricing. After launch you can request hourly support for one-off updates, or a small monthly retainer if you want predictable help with content, tweaks, and analytics.',
  },
  {
    q: 'Can you migrate or rebuild my existing website?',
    a: 'Yes. We start with an audit of your current site, identify what is working and what is hurting conversion, and rebuild with a sharper structure. We can keep your existing copy, refine it, or rewrite the structure with you.',
  },
  {
    q: 'Do I need to provide my own copy and images?',
    a: 'You can bring your own copy or work with us to refine it. For images, we use a mix of yours, licensed stock, and AI-generated visuals where appropriate. We do not write long-form marketing copy from scratch as part of the package, but we can recommend a writer if needed.',
  },
];

const servicesPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Afia Labs Studio Services',
  provider: {
    '@type': 'Organization',
    name: 'Afia Labs',
    url: 'https://afialabs.net',
  },
  serviceType: 'Website design and development',
  areaServed: 'Worldwide',
  description,
  url: 'https://afialabs.net/services/',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Afia Labs Studio Services packages',
    itemListElement: [
      {
        '@type': 'Offer',
        url: 'https://afialabs.net/services/#packages',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '750',
          priceCurrency: 'USD',
          minPrice: '750',
          valueAddedTaxIncluded: false,
        },
        itemOffered: {
          '@type': 'Service',
          name: 'Launch Page',
          description:
            'A polished one-page responsive website for new businesses, creators, or offers that need to look credible fast. Includes mobile-first design, clear CTA, contact form, basic SEO, and one revision round.',
        },
      },
      {
        '@type': 'Offer',
        url: 'https://afialabs.net/services/#packages',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '2000',
          priceCurrency: 'USD',
          minPrice: '2000',
          valueAddedTaxIncluded: false,
        },
        itemOffered: {
          '@type': 'Service',
          name: 'Business Website',
          description:
            'A 4 to 7 page website for small businesses that need a stronger online presence. Includes homepage, About, Services, and Contact pages, conversion-focused copy structure, contact or booking flow, basic SEO, analytics setup, and two revision rounds.',
        },
      },
      {
        '@type': 'Offer',
        url: 'https://afialabs.net/services/#packages',
        itemOffered: {
          '@type': 'Service',
          name: 'Growth System',
          description:
            'For businesses that need more than a site. Includes website strategy, landing pages or funnels, email capture, booking and contact automation, analytics and conversion tracking, optional AI chatbot or smart FAQ, and priority support.',
        },
      },
    ],
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://afialabs.net/services/"
  ogType="website"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(servicesPageJsonLd)}
  />

  <main>
    <section class="hero services-hero" aria-label="Studio services intro">
      <div class="container">
        <div class="hero-text services-hero-text">
          <div class="hero-badge">
            <span></span>
            Afia Labs Studio Services
          </div>
          <h1>
            Websites that make your business look <span class="accent">real</span>, and help customers take action.
          </h1>
          <p>
            Afia Labs builds clean, modern websites, landing pages, and digital systems for small businesses, creators, and founders who need more than a pretty page.
          </p>
          <p class="services-bridge-line">
            The same product thinking behind Afia Labs apps, now available for small businesses, creators, and founders.
          </p>
          <div class="hero-buttons">
            <a href="#contact" class="btn-primary" data-services-cta>
              Start a Project
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a href="#contact" class="btn-secondary" data-services-audit>
              Request a Website Audit
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="services-band services-positioning" aria-label="Positioning">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Positioning</div>
          <h2 class="section-title">Not just a website. A digital front door.</h2>
          <p class="section-subtitle">
            Your website should do more than sit online. It should help people understand what you offer, trust your business, and know exactly what to do next. Afia Labs brings product thinking, clean design, and conversion-focused structure to every site we build.
          </p>
        </div>
      </div>
    </section>

    <section class="services-band services-build" aria-label="What we build">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">What we build</div>
          <h2 class="section-title">A few of the most common projects we take on.</h2>
        </div>
        <ul class="build-list fade-in">
          <li><span class="check">✓</span> Business websites</li>
          <li><span class="check">✓</span> Landing pages</li>
          <li><span class="check">✓</span> Service pages</li>
          <li><span class="check">✓</span> Booking and contact flows</li>
          <li><span class="check">✓</span> Lead capture pages</li>
          <li><span class="check">✓</span> Founder and creator pages</li>
          <li><span class="check">✓</span> Simple automation add-ons</li>
        </ul>
      </div>
    </section>

    <section id="packages" class="services-band services-packages" aria-label="Service packages">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Packages</div>
          <h2 class="section-title">Three ways to work with us.</h2>
          <p class="section-subtitle">Pick the size that fits where you are right now. Every project starts with a short kickoff call so we get the brief right.</p>
        </div>

        <div class="services-grid">
          <article class="service-card fade-in fade-in-delay-1">
            <div class="service-tier">Launch Page</div>
            <div class="service-price">Projects start at $750</div>
            <p class="service-pitch">
              A polished one-page site for new businesses, creators, or offers that need to look credible fast.
            </p>
            <ul class="service-features">
              <li><span class="check">✓</span> One-page responsive website</li>
              <li><span class="check">✓</span> Mobile-first design</li>
              <li><span class="check">✓</span> Clear CTA section</li>
              <li><span class="check">✓</span> Contact form</li>
              <li><span class="check">✓</span> Basic SEO setup</li>
              <li><span class="check">✓</span> 1 revision round</li>
            </ul>
            <a href="#contact" class="btn-primary service-cta" data-services-tier="Launch Page">Start a Project</a>
          </article>

          <article class="service-card service-card-featured fade-in fade-in-delay-2">
            <div class="service-tier">Business Website</div>
            <div class="service-price">Projects start at $2,000</div>
            <p class="service-pitch">
              A complete website for small businesses that need a stronger online presence and better customer flow.
            </p>
            <ul class="service-features">
              <li><span class="check">✓</span> 4 to 7 core pages</li>
              <li><span class="check">✓</span> Homepage, About, Services, Contact</li>
              <li><span class="check">✓</span> Conversion-focused copy structure</li>
              <li><span class="check">✓</span> Contact or booking flow</li>
              <li><span class="check">✓</span> Basic SEO setup</li>
              <li><span class="check">✓</span> Analytics setup</li>
              <li><span class="check">✓</span> 2 revision rounds</li>
            </ul>
            <a href="#contact" class="btn-primary service-cta" data-services-tier="Business Website">Start a Project</a>
          </article>

          <article class="service-card fade-in fade-in-delay-3">
            <div class="service-tier">Growth System</div>
            <div class="service-price">Custom quote</div>
            <p class="service-pitch">
              For businesses that need more than a site. Lead capture, automations, analytics, and smarter customer journeys.
            </p>
            <ul class="service-features">
              <li><span class="check">✓</span> Full website strategy</li>
              <li><span class="check">✓</span> Landing pages or funnels</li>
              <li><span class="check">✓</span> Email capture</li>
              <li><span class="check">✓</span> Booking and contact automation</li>
              <li><span class="check">✓</span> Analytics and conversion tracking</li>
              <li><span class="check">✓</span> Optional AI chatbot or smart FAQ</li>
              <li><span class="check">✓</span> Priority support</li>
            </ul>
            <a href="#contact" class="btn-primary service-cta" data-services-tier="Growth System">Start a Project</a>
          </article>
        </div>

        <p class="services-disclaimer fade-in">
          Final pricing depends on scope, timeline, content needs, integrations, and revision requirements.
        </p>
      </div>
    </section>

    <section class="services-band services-audience" aria-label="Who this is for">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Who this is for</div>
          <h2 class="section-title">Built for founders who need to look serious online.</h2>
        </div>
        <ul class="audience-list fade-in">
          <li><span class="check">✓</span> Local service businesses</li>
          <li><span class="check">✓</span> Solo founders</li>
          <li><span class="check">✓</span> Coaches and consultants</li>
          <li><span class="check">✓</span> Creators with offers</li>
          <li><span class="check">✓</span> Small businesses that look outdated online</li>
          <li><span class="check">✓</span> Startup founders who need a polished landing page</li>
        </ul>
      </div>
    </section>

    <section class="services-band services-process" aria-label="How it works">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Process</div>
          <h2 class="section-title">How it works.</h2>
          <p class="section-subtitle">A short, predictable path from "we should fix the website" to a site that works.</p>
        </div>

        <ol class="process-grid">
          <li class="process-card fade-in fade-in-delay-1">
            <div class="process-step">1</div>
            <h3>Audit</h3>
            <p>We review your current website, brand, goals, and customer journey.</p>
          </li>
          <li class="process-card fade-in fade-in-delay-2">
            <div class="process-step">2</div>
            <h3>Strategy</h3>
            <p>We define the pages, message, CTA, and structure your site needs.</p>
          </li>
          <li class="process-card fade-in fade-in-delay-3">
            <div class="process-step">3</div>
            <h3>Build</h3>
            <p>We design and build a clean, responsive website that feels modern and trustworthy.</p>
          </li>
          <li class="process-card fade-in fade-in-delay-3">
            <div class="process-step">4</div>
            <h3>Launch</h3>
            <p>We help you go live with the basics in place: forms, SEO, analytics, and next-step recommendations.</p>
          </li>
        </ol>
      </div>
    </section>

    <section class="services-band services-proof" aria-label="Why Afia Labs">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Why Afia Labs</div>
          <h2 class="section-title">Built by a real product studio.</h2>
          <p class="section-subtitle">
            Afia Labs does not approach websites like decoration. We build digital products, mobile apps, and user experiences, so every website is designed with clarity, trust, and action in mind.
          </p>
        </div>
        <ul class="proof-list fade-in">
          <li><span class="check">✓</span> Product-first thinking</li>
          <li><span class="check">✓</span> Mobile-first design</li>
          <li><span class="check">✓</span> Clear user flows</li>
          <li><span class="check">✓</span> Conversion-focused layouts</li>
          <li><span class="check">✓</span> AI-enhanced workflows when useful</li>
        </ul>
      </div>
    </section>

    <section class="services-band services-faq-section" aria-label="Frequently asked questions">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">FAQ</div>
          <h2 class="section-title">Common questions before starting a project.</h2>
          <p class="section-subtitle">Cost, timeline, platform, and what's included. The questions we hear most from founders and small-business owners.</p>
        </div>
        <div class="services-faq-wrap">
          <FAQ items={servicesFaq} heading="" />
        </div>
      </div>
    </section>

    <section id="contact" class="services-band services-form-section" aria-label="Project inquiry">
      <span id="start" aria-hidden="true" class="anchor-compat"></span>
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">Tell us about your project</div>
          <h2 class="section-title">Start a project with Afia Labs.</h2>
          <p class="section-subtitle">
            We'll review your inquiry and follow up with next steps. No pressure, no hard sell.
          </p>
        </div>

        <form id="servicesForm" class="services-form fade-in" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label for="sf-name">Name <span class="required">*</span></label>
              <input id="sf-name" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="form-field">
              <label for="sf-email">Email <span class="required">*</span></label>
              <input id="sf-email" name="email" type="email" autocomplete="email" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="sf-phone">Phone</label>
              <input id="sf-phone" name="phone" type="tel" autocomplete="tel" placeholder="Optional" />
            </div>
            <div class="form-field">
              <label for="sf-business">Business name</label>
              <input id="sf-business" name="business" type="text" autocomplete="organization" />
            </div>
          </div>

          <div class="form-field">
            <label for="sf-current-url">Current website (if any)</label>
            <input id="sf-current-url" name="current_url" type="url" placeholder="https://" autocomplete="url" />
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="sf-project-type">Project type <span class="required">*</span></label>
              <select id="sf-project-type" name="project_type" required>
                <option value="" disabled selected>Choose one</option>
                <option value="Launch Page">Launch Page</option>
                <option value="Business Website">Business Website</option>
                <option value="Growth System">Growth System</option>
                <option value="Website Audit">Website Audit</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>
            <div class="form-field">
              <label for="sf-budget">Budget range <span class="required">*</span></label>
              <select id="sf-budget" name="budget" required>
                <option value="" disabled selected>Choose one</option>
                <option value="Under $1k">Under $1k</option>
                <option value="$1k–$2.5k">$1k to $2.5k</option>
                <option value="$2.5k–$5k">$2.5k to $5k</option>
                <option value="$5k–$10k">$5k to $10k</option>
                <option value="$10k+">$10k+</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>
          </div>

          <div class="form-field">
            <label for="sf-message">Tell us about your project <span class="required">*</span></label>
            <textarea id="sf-message" name="message" rows="6" required placeholder="What are you building? What does your current site look like? What do you want customers to do next?"></textarea>
          </div>

          <div class="form-field form-honeypot" aria-hidden="true">
            <label for="sf-botcheck">Leave this empty</label>
            <input id="sf-botcheck" name="botcheck" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-primary" id="sf-submit">Send inquiry</button>
            <p class="form-fallback">
              Prefer email? Contact us at <a href="mailto:support@afialabs.net">support@afialabs.net</a>.
            </p>
          </div>

          <div class="form-status" id="sf-status" role="status" aria-live="polite"></div>
        </form>
      </div>
    </section>

    <section class="services-band services-final-cta" aria-label="Final call to action">
      <div class="container">
        <div class="final-cta-card fade-in">
          <h2>Ready to make your business look serious online?</h2>
          <p>
            Tell us what you're building, what your current website looks like, and what you want customers to do next.
          </p>
          <a href="#contact" class="btn-primary">Start a Project</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (function () {
    const params = new URLSearchParams(window.location.search);

    // Allow tier-specific deep links: /services/?tier=Business%20Website
    const projectTypeSelect = document.getElementById('sf-project-type');
    if (projectTypeSelect) {
      const tier = params.get('tier');
      if (tier) {
        const opt = Array.from(projectTypeSelect.options).find(function (o) { return o.value === tier; });
        if (opt) projectTypeSelect.value = tier;
      }
    }

    // "Request a Website Audit" CTA pre-selects the audit option.
    const auditBtn = document.querySelector('[data-services-audit]');
    if (auditBtn && projectTypeSelect) {
      auditBtn.addEventListener('click', function () {
        projectTypeSelect.value = 'Website Audit';
      });
    }

    // Package-card CTAs pre-select the matching tier.
    document.querySelectorAll('[data-services-tier]').forEach(function (el) {
      el.addEventListener('click', function () {
        const tier = el.getAttribute('data-services-tier');
        if (projectTypeSelect && tier) projectTypeSelect.value = tier;
      });
    });

    const form = document.getElementById('servicesForm');
    const status = document.getElementById('sf-status');
    const submit = document.getElementById('sf-submit');
    if (!form) return;

    const WEB3FORMS_ACCESS_KEY = 'beee0115-97e9-4c38-bd91-052332eff5d1';

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      if (!status || !submit) return;

      status.className = 'form-status';
      status.textContent = '';

      const data = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        phone: form.phone.value.trim(),
        business: form.business.value.trim(),
        current_url: form.current_url.value.trim(),
        project_type: form.project_type.value,
        budget: form.budget.value,
        message: form.message.value.trim(),
        botcheck: form.botcheck.value,
      };

      submit.disabled = true;
      submit.textContent = 'Sending…';

      const payload = {
        access_key: WEB3FORMS_ACCESS_KEY,
        subject: 'New project inquiry from ' + data.name + ' (' + data.project_type + ')',
        from_name: 'Afia Labs Studio Services',
        botcheck: data.botcheck,
        name: data.name,
        email: data.email,
        phone: data.phone || '(not provided)',
        business: data.business || '(not provided)',
        current_website: data.current_url || '(not provided)',
        project_type: data.project_type,
        budget: data.budget,
        message: data.message,
      };

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(function () { return {}; });
        if (res.ok && json.success) {
          form.style.display = 'none';
          status.className = 'form-status form-status-success';
          status.innerHTML =
            "Thanks, we received your inquiry. We'll review it and follow up with next steps.";
          const finalCta = document.querySelector('.services-final-cta');
          if (finalCta) finalCta.style.display = 'none';
          return;
        }
        throw new Error(json.message || 'send-failed');
      } catch (err) {
        status.className = 'form-status form-status-error';
        const subject = encodeURIComponent('Project inquiry');
        const body = encodeURIComponent(
          'Name: ' + data.name + '\n' +
          'Email: ' + data.email + '\n' +
          'Phone: ' + data.phone + '\n' +
          'Business: ' + data.business + '\n' +
          'Current site: ' + data.current_url + '\n' +
          'Project type: ' + data.project_type + '\n' +
          'Budget: ' + data.budget + '\n\n' +
          data.message
        );
        status.innerHTML =
          "Something went wrong sending your inquiry. Please try again, or " +
          '<a href="mailto:support@afialabs.net?subject=' + subject + '&body=' + body +
          '">email us directly</a>.';
        submit.disabled = false;
        submit.textContent = 'Send inquiry';
      }
    });
  })();
</script>

<style>
  /* Backwards-compat anchor: the form section's id was renamed from "start"
     to "contact". This empty span keeps any external /services/#start links
     scrolling to the same place. */
  .anchor-compat {
    display: block;
    width: 0;
    height: 0;
  }

  /* ===== Services hero (single column, no device mockup) ===== */
  .services-hero .container {
    max-width: 880px;
  }
  .services-hero-text {
    text-align: center;
    margin: 0 auto;
  }
  .services-hero-text .hero-badge {
    margin-left: auto;
    margin-right: auto;
  }
  .services-hero-text h1 {
    margin-left: auto;
    margin-right: auto;
    max-width: 820px;
  }
  .services-hero-text p {
    margin-left: auto;
    margin-right: auto;
  }
  .services-hero-text .hero-buttons {
    justify-content: center;
  }
  .services-bridge-line {
    margin: 0 auto 28px;
    max-width: 640px;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ===== Section rhythm ===== */
  .services-band {
    padding: 96px 0;
  }
  .services-band:nth-of-type(even) {
    background: var(--bg-white);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  /* ===== "What we build" + audience + proof: feature lists ===== */
  .build-list,
  .audience-list,
  .proof-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 32px;
    row-gap: 14px;
    max-width: 720px;
    margin: 0 auto;
  }
  .build-list li,
  .audience-list li,
  .proof-list li {
    display: flex;
