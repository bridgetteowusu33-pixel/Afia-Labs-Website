---
// PreLaunchHero.astro — Shared hero pattern for the 4 hidden pre-launch pages
// (book, workbook, course, bundle). Props drive the content and accent color
// so each page has its own identity while sharing the layout.

export interface Props {
  eyebrow: string;           // e.g. "1 of 4 · The Book"
  accentColor: string;       // hex, e.g. "#f59e0b"
  headline: string;          // big title
  subhead: string;           // tagline
  meta?: string;             // small line under the CTAs
  primaryCtaText?: string;
  primaryCtaHref?: string;
  primaryCtaTarget?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  eyebrow,
  accentColor,
  headline,
  subhead,
  meta = 'Coming soon from Afia Labs · by Bridgette Owusu',
  primaryCtaText = 'Join the Waitlist',
  primaryCtaHref = 'https://form.jotform.com/261045381980054',
  primaryCtaTarget = '_blank',
  secondaryCtaText,
  secondaryCtaHref,
} = Astro.props;
---

<section class="pre-hero" style={`--accent: ${accentColor};`}>
  <div class="pre-hero-glow pre-hero-glow-1" aria-hidden="true"></div>
  <div class="pre-hero-glow pre-hero-glow-2" aria-hidden="true"></div>
  <div class="pre-hero-noise" aria-hidden="true"></div>

  <div class="container pre-hero-inner">
    <div class="pre-hero-eyebrow">
      <span class="pre-hero-eyebrow-dot" aria-hidden="true"></span>
      {eyebrow}
    </div>

    <h1 class="pre-hero-headline">{headline}</h1>

    <p class="pre-hero-subhead">{subhead}</p>

    <div class="pre-hero-ctas">
      <a
        href={primaryCtaHref}
        target={primaryCtaTarget}
        rel={primaryCtaTarget === '_blank' ? 'noopener noreferrer' : undefined}
        class="pre-hero-btn pre-hero-btn-primary"
      >
        {primaryCtaText}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="pre-hero-btn pre-hero-btn-secondary">
          {secondaryCtaText}
        </a>
      )}
    </div>

    {meta && <p class="pre-hero-meta">{meta}</p>}
  </div>
</section>

<style>
  .pre-hero {
    position: relative;
    padding: 160px 0 120px;
    background: linear-gradient(180deg, #0a0612 0%, #12091f 60%, #0f0818 100%);
    color: #fffbf7;
    overflow: hidden;
  }

  .pre-hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .pre-hero-glow-1 {
    top: -120px;
    left: -140px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 38%, transparent) 0%, transparent 70%);
  }

  .pre-hero-glow-2 {
    bottom: -160px;
    right: -120px;
    width: 440px;
    height: 440px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 24%, transparent) 0%, transparent 70%);
  }

  .pre-hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.3) 0px,
      rgba(255, 255, 255, 0.3) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
  }

  .pre-hero-inner {
    position: relative;
    z-index: 2;
    text-align: left;
    max-width: 900px;
  }

  .pre-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    color: var(--accent);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    margin-bottom: 36px;
  }

  .pre-hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .pre-hero-headline {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: clamp(42px, 7vw, 96px);
    font-weight: 900;
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: #fffbf7;
    margin: 0 0 32px;
    max-width: 14ch;
    text-wrap: balance;
  }

  .pre-hero-subhead {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 500;
    line-height: 1.5;
    color: rgba(255, 251, 247, 0.72);
    margin: 0 0 44px;
    max-width: 52ch;
    letter-spacing: -0.005em;
  }

  .pre-hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .pre-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 32px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.005em;
    border-radius: 999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .pre-hero-btn-primary {
    background: var(--accent);
    color: #0a0612;
    box-shadow:
      0 12px 28px color-mix(in srgb, var(--accent) 38%, transparent),
      0 2px 0 rgba(255, 255, 255, 0.12) inset;
  }

  .pre-hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 18px 38px color-mix(in srgb, var(--accent) 48%, transparent),
      0 2px 0 rgba(255, 255, 255, 0.16) inset;
  }

  .pre-hero-btn-secondary {
    background: transparent;
    color: #fffbf7;
    border: 1.5px solid rgba(255, 251, 247, 0.2);
  }

  .pre-hero-btn-secondary:hover {
    border-color: rgba(255, 251, 247, 0.4);
    background: rgba(255, 251, 247, 0.04);
  }

  .pre-hero-meta {
    font-size: 13px;
    color: rgba(255, 251, 247, 0.42);
    letter-spacing: 0.01em;
    margin: 0;
  }

  @media (max-width: 860px) {
    .pre-hero {
      padding: 120px 0 80px;
    }

    .pre-hero-eyebrow {
      margin-bottom: 28px;
    }

    .pre-hero-headline {
      margin-bottom: 24px;
    }

    .pre-hero-subhead {
      margin-bottom: 36px;
    }

    .pre-hero-ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .pre-hero-btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>
