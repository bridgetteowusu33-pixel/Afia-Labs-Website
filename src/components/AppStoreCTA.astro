---
export interface Props {
  heading?: string;
  body?: string;
  label?: string;
}

const {
  heading = 'Free up storage on your iPhone — today.',
  body = 'MemeScanr is free to try, works offline, and never uploads your photos. Download it on the App Store.',
  label = 'Download MemeScanr',
} = Astro.props;
---

<aside class="cta-block">
  <h3>{heading}</h3>
  <p>{body}</p>
  <a
    class="btn-cta"
    href="https://apps.apple.com/us/app/memescanr-save-phone-storage/id6758227953"
    target="_blank"
    rel="noopener noreferrer"
  >
    {label}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</aside>
